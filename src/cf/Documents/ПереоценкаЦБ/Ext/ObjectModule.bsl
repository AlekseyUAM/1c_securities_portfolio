#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Движения.СобственныеЦБ.Записывать = Истина;
	Движения.СобственныеЦБ.Очистить();

	ПровестиПереоценку(Отказ);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПровестиПереоценку(Отказ)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.ЦеннаяБумага КАК ЦеннаяБумага,
	|	Остатки.Партия КАК Партия,
	|	Остатки.КоличествоОстаток КАК КоличествоОстаток,
	|	Остатки.СтоимостьОстаток КАК СтоимостьОстаток,
	|	Остатки.ПереоценкаОстаток КАК ПереоценкаОстаток,
	|	ЕСТЬNULL(Котировки.Значение, 0) КАК Котировка
	|ИЗ
	|	РегистрНакопления.СобственныеЦБ.Остатки(&МоментВремени, ) КАК Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КотировкиЦБ.СрезПоследних(
	|			&Дата,
	|			ВидКотировки = &ВидКотировки) КАК Котировки
	|		ПО Остатки.ЦеннаяБумага = Котировки.ЦеннаяБумага
	|ГДЕ
	|	Остатки.КоличествоОстаток > 0";

	Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ВидКотировки", Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		Если Выборка.Котировка = 0 Тогда
			Продолжить;
		КонецЕсли;

		РыночнаяСтоимость = Выборка.Котировка * Выборка.КоличествоОстаток;
		БалансоваяСтоимость = Выборка.СтоимостьОстаток + Выборка.ПереоценкаОстаток;
		Разница = РыночнаяСтоимость - БалансоваяСтоимость;

		Если Разница = 0 Тогда
			Продолжить;
		КонецЕсли;

		Движение = Движения.СобственныеЦБ.Добавить();

		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Переоценка = Разница;
		Движение.Период = Дата;
		Движение.ЦеннаяБумага = Выборка.ЦеннаяБумага;
		Движение.Партия = Выборка.Партия;
		Движение.Количество = 0;
		Движение.Стоимость = 0;
		Движение.Затраты = 0;
		Движение.НКДПолученный = 0;
		Движение.НКДНакопленный = 0;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли