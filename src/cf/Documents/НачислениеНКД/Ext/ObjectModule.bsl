#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Движения.СобственныеЦБ.Записывать = Истина;
	Движения.СобственныеЦБ.Очистить();

	НачислитьНКДПоПартиям(Отказ);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура НачислитьНКДПоПартиям(Отказ)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СобственныеЦБОстатки.Партия КАК Партия,
	|	СобственныеЦБОстатки.Партия.Дата КАК ДатаПартии,
	|	СобственныеЦБОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.СобственныеЦБ.Остатки(
	|		&МоментВремени,
	|		ЦеннаяБумага = &ЦеннаяБумага) КАК СобственныеЦБОстатки
	|ГДЕ
	|	СобственныеЦБОстатки.КоличествоОстаток > 0
	|УПОРЯДОЧИТЬ ПО
	|	ДатаПартии,
	|	СобственныеЦБОстатки.Партия";

	Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
	Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

	ТаблицаОстатков = Запрос.Выполнить().Выгрузить();

	Если ТаблицаОстатков.Количество() = 0 Тогда
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Нет остатков ЦБ ""%1"" для начисления НКД.'"),
			Строка(ЦеннаяБумага));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект);
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаОстатков Из ТаблицаОстатков Цикл

		НКДПартии = НКД * СтрокаОстатков.КоличествоОстаток;

		Движение = Движения.СобственныеЦБ.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.ЦеннаяБумага = ЦеннаяБумага;
		Движение.Партия = СтрокаОстатков.Партия;
		Движение.Количество = 0;
		Движение.Стоимость = 0;
		Движение.Переоценка = 0;
		Движение.Затраты = 0;
		Движение.НКДПолученный = 0;
		Движение.НКДНакопленный = НКДПартии;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли
