
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Объект.БазовыйURLAPI = "https://iss.moex.com/iss";
	Объект.BOARDIDАкций = "TQBR";
	Объект.BOARDIDОблигаций = "TQCB";

	ЗагрузитьСписокЦенныхБумаг();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Загрузить(Команда)

	Если Не ЗначениеЗаполнено(Объект.НачалоПериода)
		Или Не ЗначениеЗаполнено(Объект.ОкончаниеПериода) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите период загрузки.'"));
		Возврат;
	КонецЕсли;

	Результат = ЗагрузитьНаСервере();

	ТекстСообщения = СтрШаблон(
		НСтр("ru = 'Загрузка завершена.
		|Обработано бумаг: %1
		|Загружено котировок: %2
		|Бумаг без данных: %3
		|Ошибок: %4'"),
		Результат.ОбработаноБумаг,
		Результат.ЗагруженоКотировок,
		Результат.БумагиБезДанных,
		Результат.Ошибки.Количество());

	ПоказатьПредупреждение(, ТекстСообщения);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ЗагрузитьНаСервере()

	СписокЦБ = Новый Массив;

	Для Каждого СтрокаТЧ Из Объект.СписокЦБ Цикл

		Если Не СтрокаТЧ.Загружать Тогда
			Продолжить;
		КонецЕсли;

		Если Не ЗначениеЗаполнено(СтрокаТЧ.Тикер) Тогда
			Продолжить;
		КонецЕсли;

		ЭлементСписка = Новый Структура;
		ЭлементСписка.Вставить("ЦеннаяБумага", СтрокаТЧ.ЦеннаяБумага);
		ЭлементСписка.Вставить("Тикер", СтрокаТЧ.Тикер);
		ЭлементСписка.Вставить("ТипБумагиКод", СтрокаТЧ.ТипБумагиКод);
		СписокЦБ.Добавить(ЭлементСписка);

	КонецЦикла;

	ПараметрыЗагрузки = Новый Структура;
	ПараметрыЗагрузки.Вставить("НачалоПериода", Объект.НачалоПериода);
	ПараметрыЗагрузки.Вставить("ОкончаниеПериода", Объект.ОкончаниеПериода);
	ПараметрыЗагрузки.Вставить("СписокЦБ", СписокЦБ);
	ПараметрыЗагрузки.Вставить("БазовыйURL", Объект.БазовыйURLAPI);
	ПараметрыЗагрузки.Вставить("BOARDIDАкций", Объект.BOARDIDАкций);
	ПараметрыЗагрузки.Вставить("BOARDIDОблигаций", Объект.BOARDIDОблигаций);

	Возврат РаботаСКотировкамиЦБ.ЗагрузитьКотировкиСМОЕХ(ПараметрыЗагрузки);

КонецФункции

&НаСервере
Процедура ЗагрузитьСписокЦенныхБумаг()

	Объект.СписокЦБ.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦенныеБумаги.Ссылка КАК ЦеннаяБумага,
	|	ЦенныеБумаги.Тикер КАК Тикер,
	|	ЦенныеБумаги.ТипБумагиКод КАК ТипБумагиКод
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	НЕ ЦенныеБумаги.ПометкаУдаления
	|	И ЦенныеБумаги.Тикер <> """"
	|УПОРЯДОЧИТЬ ПО
	|	ЦенныеБумаги.Наименование";

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		НовСтр = Объект.СписокЦБ.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Выборка);
		НовСтр.Загружать = Истина;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
