// Модуль формы элемента справочника ЦенныеБумаги.
// Обеспечивает загрузку данных из MOEX ISS API

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьИзMOEX(Команда)

	Если Не ЗначениеЗаполнено(Объект.Тикер) И Не ЗначениеЗаполнено(Объект.ISIN) Тогда
    		ОбщегоНазначенияКлиент.СообщитьПользователю("Нужно заполнить Тикер или ISIN");
		Возврат;
	КонецЕсли;

	Результат = ВыполнитьЗагрузкуНаСервере(Объект.Тикер, Объект.ISIN);

	Если Результат.Успех Тогда
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Загрузка из MOEX'"),
			,
			СтрШаблон(НСтр("ru = 'Данные по ""%1"" успешно загружены из MOEX.'"), Объект.Тикер),
			БиблиотекаКартинок.Информация32);
	Иначе
		ПоказатьПредупреждение(, Результат.ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ВыполнитьЗагрузкуНаСервере(Знач Тикер, Знач ISIN)

	Результат = ЦенныеБумагиСервер.ЗагрузитьИзMOEX(Тикер, ISIN);

	Если Не Результат.Успех Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, Результат.ДанныеБумаги);
	Объект.Валюта = ЦенныеБумагиСервер.НайтиВалютуПоКоду(Результат.ДанныеБумаги.КодВалюты);
	Объект.ДатаЗагрузки = ТекущаяДатаСеанса();
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
