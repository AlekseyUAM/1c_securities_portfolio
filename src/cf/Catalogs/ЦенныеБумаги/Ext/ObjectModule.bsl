#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Проверяет уникальность реквизита ISIN среди элементов справочника.
// При нахождении дублирующего ISIN вызывает ОбщегоНазначения.СообщитьПользователю
// и устанавливает Отказ = Истина.
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	Если Не ЗначениеЗаполнено(ISIN) Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЦенныеБумаги.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЦенныеБумаги КАК ЦенныеБумаги
	|ГДЕ
	|	ЦенныеБумаги.ISIN = &ISIN
	|	И ЦенныеБумаги.Ссылка <> &ТекущаяСсылка";

	Запрос.УстановитьПараметр("ISIN", ISIN);
	Запрос.УстановитьПараметр("ТекущаяСсылка", Ссылка);

	Если Не Запрос.Выполнить().Пустой() Тогда
		ОбщегоНазначения.СообщитьПользователю(
			СтрШаблон(НСтр("ru = 'Ценная бумага с ISIN ""%1"" уже существует в справочнике.'"), ISIN),
			ЭтотОбъект, "ISIN", , Отказ);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Иначе
	ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли
