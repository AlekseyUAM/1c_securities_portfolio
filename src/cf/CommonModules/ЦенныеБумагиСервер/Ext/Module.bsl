// Серверный модуль для работы с ценными бумагами.
// Реализует загрузку карточки ценной бумаги из MOEX ISS API,
// проверку доступности кнопки загрузки и поиск валюты по коду.

#Область ПрограммныйИнтерфейс

// Загружает реквизиты ценной бумаги из MOEX ISS API.
// Тикер или ISIN - хотя бы одно должно быть заполнено.
// Функция только получает и возвращает данные, без записи в БД.
//
// Параметры:
//   Тикер - Строка - тикер (SECID) бумаги; может быть пустой строкой.
//   ISIN  - Строка - код ISIN бумаги; может быть пустой строкой.
//
// Возвращаемое значение:
//   Структура:
//   * Успех         - Булево
//   * ДанныеБумаги  - Структура - значения реквизитов (при Успех = Истина)
//   * ТекстОшибки   - Строка  - описание ошибки (при Успех = Ложь)
//   * КодОшибки     - Строка  - "СоединениеОтсутствует" | "ОшибкаHTTP" | "БумагаНеНайдена"
//
Функция ЗагрузитьИзMOEX(Знач Тикер, Знач ISIN) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ДанныеБумаги", Неопределено);
	Результат.Вставить("ТекстОшибки", "");
	Результат.Вставить("КодОшибки", "");

	// Определяем идентификатор для запроса: тикер имеет приоритет
	ИдБумаги = СокрЛП(Тикер);
	Если Не ЗначениеЗаполнено(ИдБумаги) Тогда
		ИдБумаги = СокрЛП(ISIN);
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ИдБумаги) Тогда
		Результат.ТекстОшибки = НСтр("ru = 'Не указан тикер или ISIN для загрузки.'");
		Результат.КодОшибки = "БумагаНеНайдена";
		Возврат Результат;
	КонецЕсли;

	// Выполняем HTTP-запрос к MOEX ISS API
	ОтветHTTP = Неопределено;
	Попытка
		ОтветHTTP = ВыполнитьHTTPЗапрос(ИдБумаги);
	Исключение
		Результат.ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Ошибка соединения с MOEX ISS API: %1'"),
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Результат.КодОшибки = "СоединениеОтсутствует";

		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'ЦенныеБумаги.ЗагрузкаИзMOEX'"),
			УровеньЖурналаРегистрации.Ошибка, , ,
			Результат.ТекстОшибки);

		Возврат Результат;
	КонецПопытки;

	// Проверяем код состояния HTTP-ответа
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		Результат.ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Сервис MOEX вернул ошибку: %1'"),
			ОтветHTTP.КодСостояния);
		Результат.КодОшибки = "ОшибкаHTTP";
		Возврат Результат;
	КонецЕсли;

	// Разбираем JSON-ответ
	ДанныеОтвета = РазобратьОтветJSON(ОтветHTTP.Тело);
	Если ДанныеОтвета = Неопределено Тогда
		Результат.ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Ценная бумага ""%1"" не найдена в MOEX.'"),
			ИдБумаги);
		Результат.КодОшибки = "БумагаНеНайдена";
		Возврат Результат;
	КонецЕсли;

	// Формируем структуру данных бумаги
	ДанныеБумаги = СформироватьДанныеБумаги(ДанныеОтвета);

	Результат.Успех = Истина;
	Результат.ДанныеБумаги = ДанныеБумаги;

	Возврат Результат;

КонецФункции

// Возвращает ссылку на элемент Справочник.Валюты по символьному коду.
// Поиск по реквизиту Наименование (символьный ISO-код).
//
// Параметры:
//   КодВалюты - Строка - символьный код валюты из поля FACEUNIT ответа MOEX
//
// Возвращаемое значение:
//   СправочникСсылка.Валюты - найденный элемент, или ПустаяСсылка() если не найден.
//
Функция НайтиВалютуПоКоду(Знач КодВалюты) Экспорт

	Если Не ЗначениеЗаполнено(КодВалюты) Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	Если  КодВалюты = "SUR" Тогда // Советский рубль
		КодВалюты = "RUB"; 
	КонецЕсли;

	Возврат Справочники.Валюты.НайтиПоНаименованию(СокрЛП(КодВалюты), Истина);

КонецФункции

// Выполняет HTTP-запрос к MOEX ISS API для получения карточки ценной бумаги.
// Экспортная функция для возможности мокирования в тестах.
//
// Параметры:
//   ИдБумаги - Строка - идентификатор бумаги (тикер или ISIN)
//
// Возвращаемое значение:
//   Структура:
//   * КодСостояния - Число - HTTP-код ответа
//   * Тело         - Строка - тело ответа (JSON)
//
Функция ВыполнитьHTTPЗапрос(Знач ИдБумаги) Экспорт

	АдресРесурса = СтрШаблон("/iss/securities/%1.json?iss.meta=off&description.columns=name,title,value", ИдБумаги);

	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	Соединение = Новый HTTPСоединение("iss.moex.com", 443, , , , 30, ЗащищенноеСоединение);

	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Ответ = Соединение.Получить(Запрос);

	РезультатЗапроса = Новый Структура;
	РезультатЗапроса.Вставить("КодСостояния", Ответ.КодСостояния);
	РезультатЗапроса.Вставить("Тело", Ответ.ПолучитьТелоКакСтроку());

	Возврат РезультатЗапроса;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Разбирает JSON-ответ MOEX ISS API и возвращает соответствие полей.
// Если секция description.data пуста - возвращает Неопределено.
//
// Параметры:
//   ТелоОтвета - Строка - JSON-строка ответа MOEX
//
// Возвращаемое значение:
//   Соответствие - пары "имя поля" - "значение", или Неопределено при пустых данных
//
Функция РазобратьОтветJSON(Знач ТелоОтвета)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТелоОтвета);

	ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Если ДанныеОтвета = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Получаем секцию description
	СекцияОписания = Неопределено;
	Если ТипЗнч(ДанныеОтвета) = Тип("Соответствие") Тогда
		СекцияОписания = ДанныеОтвета.Получить("description");
	КонецЕсли;

	Если СекцияОписания = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Получаем массив data
	МассивДанных = Неопределено;
	Если ТипЗнч(СекцияОписания) = Тип("Соответствие") Тогда
		МассивДанных = СекцияОписания.Получить("data");
	КонецЕсли;

	Если МассивДанных = Неопределено
		Или ТипЗнч(МассивДанных) <> Тип("Массив")
		Или МассивДанных.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Формируем соответствие: имя поля -> значение
	// Каждый элемент data - массив [name, title, value]
	СоответствиеПолей = Новый Соответствие;
	Для Каждого СтрокаДанных Из МассивДанных Цикл
		Если ТипЗнч(СтрокаДанных) = Тип("Массив") И СтрокаДанных.Количество() >= 3 Тогда
			ИмяПоля = СтрокаДанных[0];
			ЗначениеПоля = СтрокаДанных[2];
			СоответствиеПолей.Вставить(ИмяПоля, ЗначениеПоля);
		КонецЕсли;
	КонецЦикла;

	Если СоответствиеПолей.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат СоответствиеПолей;

КонецФункции

// Формирует структуру данных бумаги из соответствия полей MOEX.
//
// Параметры:
//   СоответствиеПолей - Соответствие - пары "имя поля MOEX" - "значение"
//
// Возвращаемое значение:
//   Структура - данные бумаги для заполнения реквизитов справочника
//
Функция СформироватьДанныеБумаги(СоответствиеПолей)

	ДанныеБумаги = Новый Структура;
	ДанныеБумаги.Вставить("Наименование", ПолучитьЗначениеПоля(СоответствиеПолей, "SHORTNAME"));
	ДанныеБумаги.Вставить("НаименованиеПолное", ПолучитьЗначениеПоля(СоответствиеПолей, "NAME"));
	ДанныеБумаги.Вставить("НаименованиеЛатинское", ПолучитьЗначениеПоля(СоответствиеПолей, "LATNAME"));
	ДанныеБумаги.Вставить("Тикер", ПолучитьЗначениеПоля(СоответствиеПолей, "SECID"));
	ДанныеБумаги.Вставить("ISIN", ПолучитьЗначениеПоля(СоответствиеПолей, "ISIN"));
	ДанныеБумаги.Вставить("ТипБумаги", ПолучитьЗначениеПоля(СоответствиеПолей, "TYPENAME"));
	ДанныеБумаги.Вставить("ГруппаИнструмента", ПолучитьЗначениеПоля(СоответствиеПолей, "GROUPNAME"));
	ДанныеБумаги.Вставить("НомерРегистрации", ПолучитьЗначениеПоля(СоответствиеПолей, "REGNUMBER"));
	ДанныеБумаги.Вставить("КодВалюты", ПолучитьЗначениеПоля(СоответствиеПолей, "FACEUNIT"));
	ДанныеБумаги.Вставить("ТипИнструментаКод", ПолучитьЗначениеПоля(СоответствиеПолей, "GROUP"));
	ДанныеБумаги.Вставить("ТипБумагиКод", ПолучитьЗначениеПоля(СоответствиеПолей, "TYPE"));

	// Числовые поля
	ДанныеБумаги.Вставить("НоминальнаяСтоимость", ПолучитьЧисловоеЗначениеПоля(СоответствиеПолей, "FACEVALUE"));
	ДанныеБумаги.Вставить("УровеньЛистинга", ПолучитьЧисловоеЗначениеПоля(СоответствиеПолей, "LISTLEVEL"));
	ДанныеБумаги.Вставить("КодЭмитента", ПолучитьЧисловоеЗначениеПоля(СоответствиеПолей, "EMITTER_ID"));
	ДанныеБумаги.Вставить("ОбъёмВыпуска", ПолучитьЧисловоеЗначениеПоля(СоответствиеПолей, "ISSUESIZE"));

	// Поле даты
	ДанныеБумаги.Вставить("ДатаНачалаТоргов", ПолучитьДатуИзСтроки(ПолучитьЗначениеПоля(СоответствиеПолей, "ISSUEDATE")));

	Возврат ДанныеБумаги;

КонецФункции

// Безопасно получает строковое значение из соответствия полей.
//
// Параметры:
//   СоответствиеПолей - Соответствие
//   ИмяПоля - Строка
//
// Возвращаемое значение:
//   Строка
//
Функция ПолучитьЗначениеПоля(СоответствиеПолей, ИмяПоля)

	Значение = СоответствиеПолей.Получить(ИмяПоля);
	Если Значение = Неопределено Или Значение = NULL Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Значение);

КонецФункции

// Безопасно получает числовое значение из соответствия полей.
//
// Параметры:
//   СоответствиеПолей - Соответствие
//   ИмяПоля - Строка
//
// Возвращаемое значение:
//   Число
//
Функция ПолучитьЧисловоеЗначениеПоля(СоответствиеПолей, ИмяПоля)

	Значение = СоответствиеПолей.Получить(ИмяПоля);
	Если Значение = Неопределено Или Значение = NULL Тогда
		Возврат 0;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;

	СтрокаЗначения = СокрЛП(Строка(Значение));
	Если Не ЗначениеЗаполнено(СтрокаЗначения) Тогда
		Возврат 0;
	КонецЕсли;

	Попытка
		Возврат Число(СтрокаЗначения);
	Исключение
		Возврат 0;
	КонецПопытки;

КонецФункции

// Преобразует строку даты формата YYYY-MM-DD в значение типа Дата.
//
// Параметры:
//   СтрокаДаты - Строка - дата в формате "YYYY-MM-DD"
//
// Возвращаемое значение:
//   Дата - дата или пустая дата, если преобразование невозможно
//
Функция ПолучитьДатуИзСтроки(Знач СтрокаДаты)

	Если Не ЗначениеЗаполнено(СтрокаДаты) Тогда
		Возврат '00010101';
	КонецЕсли;

	СтрокаДаты = СокрЛП(СтрокаДаты);
	Если СтрДлина(СтрокаДаты) < 10 Тогда
		Возврат '00010101';
	КонецЕсли;

	Попытка
		Год = Число(Сред(СтрокаДаты, 1, 4));
		Месяц = Число(Сред(СтрокаДаты, 6, 2));
		День = Число(Сред(СтрокаДаты, 9, 2));
		Возврат Дата(Год, Месяц, День);
	Исключение
		Возврат '00010101';
	КонецПопытки;

КонецФункции

#КонецОбласти
