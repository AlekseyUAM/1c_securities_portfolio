// Модуль менеджера РегистрСведений.КотировкиЦБ
// Программный интерфейс для чтения котировок.

#Область ПрограммныйИнтерфейс

// Возвращает значение котировки на указанную дату (срез последних).
//
// Параметры:
//   ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//   Дата         - Дата
//   ВидКотировки - ПеречислениеСсылка.ВидыКотировокЦБ - по умолчанию ЦенаЗакрытия
//
// Возвращаемое значение:
//   Число или Неопределено - значение котировки или Неопределено если данных нет
//
Функция ПолучитьКотировку(ЦеннаяБумага, Дата, ВидКотировки = Неопределено) Экспорт

	Если ВидКотировки = Неопределено Тогда
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;
	КонецЕсли;

	Отбор = Новый Структура;
	Отбор.Вставить("ЦеннаяБумага", ЦеннаяБумага);
	Отбор.Вставить("ВидКотировки", ВидКотировки);

	РезультатСреза = РегистрыСведений.КотировкиЦБ.ПолучитьПоследнее(Дата, Отбор);

	Если Не ЗначениеЗаполнено(РезультатСреза.Значение) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат РезультатСреза.Значение;

КонецФункции

#КонецОбласти
