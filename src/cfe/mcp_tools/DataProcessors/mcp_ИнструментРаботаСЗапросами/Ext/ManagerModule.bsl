
// Менеджер MCP-инструментов проверки и выполнения запросов.

#Область ПрограммныйИнтерфейс

// Добавляет описания доступных MCP-инструментов для работы с запросами.
// Параметры:
//   Инструменты - ТаблицаЗначений - Таблица описаний инструментов MCP.
Процедура ДобавитьИнструменты(Инструменты) Экспорт
	
	МассивПараметров = Новый Массив;
	
	// Параметр: текст запроса для проверки
	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"queryText",
		"string",
		"Текст запроса 1С для проверки",
		,
		Истина)); // Обязательный параметр
	
	// Создаем схему параметров
	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);
	
	// Добавляем инструмент
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"validate_query",
		"Проверка синтаксиса запроса БЕЗ выполнения и БЕЗ обращения к базе данных. Используй для валидации сложных запросов перед выполнением или когда нужно проверить корректность синтаксиса без получения данных. Быстрая операция - только парсинг текста.",
		СхемаПараметров);

	// Параметры для выполнения запроса
	МассивПараметров = Новый Массив;

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"queryText",
		"string",
		"Текст запроса на языке запросов 1С (SELECT/ВЫБРАТЬ). Ссылочные поля автоматически конвертируются в описания объектов.",
		,
		Истина)); // Обязательный параметр

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"parameters",
		"object",
		"Параметры запроса. Можно передавать описания объектов (с полем _objectRef:true) - они автоматически конвертируются в ссылки. Пример: {'Контрагент': {_objectRef:true, УникальныйИдентификатор:'...', ТипОбъекта:'СправочникСсылка.Контрагенты'}}"));

	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"limit",
		"number",
		"Ограничение строк (по умолчанию 100, максимум 1000). При truncated:true выполни повторный запрос с уточнением условий.",
		100));

	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"execute_query",
		"ОСНОВНОЙ ИНСТРУМЕНТ для получения данных из 1С. Выполняет запрос и возвращает данные с автоматической обработкой ссылочных типов. Ссылочные поля (Контрагент, Договор и т.д.) конвертируются в описания объектов {_objectRef, УникальныйИдентификатор, ТипОбъекта, Представление}, которые можно использовать как параметры в следующих запросах. ИТЕРАТИВНЫЙ ПОДХОД: используй результаты одного запроса как параметры для следующего - так можно углубляться по связям объектов. Пример цепочки: 1) получить договор, 2) использовать его Контрагента в параметрах для поиска других договоров этого же контрагента.",
		СхемаПараметров);
	
	// Инструмент: Преобразование навигационной ссылки в описание объекта
	МассивПараметров = Новый Массив;
	
	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"navLink",
		"string",
		"Навигационная ссылка формата e1cib/data/Документ.Реализация?ref=... Пользователь может скопировать её из 1С.",
		,
		Истина)); // Обязательный параметр
	
	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);
	
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"parse_nav_link",
		"Преобразует навигационную ссылку 1С (e1cib/data/...) в описание объекта. Используй когда пользователь присылает ссылку - получи описание и используй его в параметрах execute_query для анализа этого объекта и связанных данных. Возвращает {_objectRef:true, УникальныйИдентификатор, ТипОбъекта, Представление}.",
		СхемаПараметров);
	
	// Инструмент: Получение навигационной ссылки по описанию объекта
	МассивПараметров = Новый Массив;
	
	МассивПараметров.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"objectDescription",
		"object",
		"Описание объекта с полями {_objectRef:true, УникальныйИдентификатор, ТипОбъекта}. Получаешь в результатах execute_query.",
		,
		Истина)); // Обязательный параметр
	
	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);
	
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_nav_link",
		"Получает навигационную ссылку (e1cib/data/...) по описанию объекта. Используй чтобы дать пользователю кликабельную ссылку для открытия объекта в 1С. Принимает описание объекта из результатов execute_query.",
		СхемаПараметров);
	
КонецПроцедуры

// Выполняет инструмент по имени.
// Параметры:
//   ИмяИнструмента - Строка - Имя вызываемого инструмента.
//   Аргументы - Структура - Параметры вызова.
// Возвращаемое значение:
//   Строка - JSON-строка с результатом выполнения инструмента.
Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт
	
	Если ИмяИнструмента = "validate_query" Тогда
		Возврат ПроверитьЗапрос(Аргументы.queryText);
	КонецЕсли;

	Если ИмяИнструмента = "execute_query" Тогда
		ПараметрыЗапроса = Неопределено;
		Если Аргументы.Свойство("parameters") Тогда
			ПараметрыЗапроса = Аргументы.parameters;
		КонецЕсли;
		
		Ограничение = Неопределено;
		Если Аргументы.Свойство("limit") Тогда
			Ограничение = Аргументы.limit;
		КонецЕсли;

		Возврат ВыполнитьЗапрос(
			Аргументы.queryText,
			ПараметрыЗапроса,
			Ограничение);
	КонецЕсли;
	
	Если ИмяИнструмента = "parse_nav_link" Тогда
		Возврат ОбработатьПреобразованиеНавСсылки(Аргументы.navLink);
	КонецЕсли;
	
	Если ИмяИнструмента = "get_nav_link" Тогда
		Возврат ПолучитьНавСсылкуПоОписанию(Аргументы.objectDescription);
	КонецЕсли;
	
	ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет синтаксис запроса 1С.
// Параметры:
//   ТекстЗапроса - Строка - Текст запроса 1С.
// Возвращаемое значение:
//   Строка - JSON-строка с признаком валидности и сообщением.
Функция ПроверитьЗапрос(ТекстЗапроса)
	
	Попытка
		Схема = Новый СхемаЗапроса;
		Схема.УстановитьТекстЗапроса(ТекстЗапроса);
		
		Результат = Новый Структура;
		Результат.Вставить("valid", Истина);
		Результат.Вставить("message", "Синтаксис запроса корректен");
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
		
	Исключение
		Результат = Новый Структура;
		Результат.Вставить("valid", Ложь);
		
		ТекстОшибки = ОписаниеОшибки();
		ПодсказкаИнструмент = Символы.ПС + Символы.ПС 
			+ " HINT: При ошибке запроса проверьте:" + Символы.ПС
			+ "1) Структуру объектов метаданных через get_metadata_structure (правильность имен таблиц, полей, табличных частей)" + Символы.ПС
			+ "2) Формат передаваемых параметров (объекты должны иметь структуру {_objectRef, УникальныйИдентификатор, ТипОбъекта})" + Символы.ПС
			+ "3) Если используете навигационные ссылки - сначала преобразуйте их через parse_nav_link";
		
		Результат.Вставить("message", ТекстОшибки + ПодсказкаИнструмент);
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
	КонецПопытки;
	
КонецФункции

// Выполняет запрос 1С с установкой параметров и ограничением выборки.
// Параметры:
//   ТекстЗапроса - Строка - Текст запроса 1С.
//   ПараметрыЗапроса - Структура - Параметры запроса (родные типы 1С, опционально).
//   ОграничениеВыборки - Число - Лимит строк (по умолчанию 100, максимум 1000).
// Возвращаемое значение:
//   Строка - JSON-строка с данными выборки, колонками, лимитом и признаком усечения.
Функция ВыполнитьЗапрос(ТекстЗапроса, ПараметрыЗапроса, ОграничениеВыборки)
	
	ПределПоУмолчанию = 100;
	МаксимальныйПредел = 1000;

	Предел = ПределПоУмолчанию;
	Если ОграничениеВыборки <> Неопределено Тогда
		Предел = ОграничениеВыборки;
		Если Предел <= 0 Тогда
			Предел = ПределПоУмолчанию;
		КонецЕсли;
		
		Если Предел > МаксимальныйПредел Тогда
			Предел = МаксимальныйПредел;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапроса;

		Если ПараметрыЗапроса <> Неопределено И ТипЗнч(ПараметрыЗапроса) <> Тип("Структура") Тогда
			ВызватьИсключение "Параметры запроса должны быть структурой";
		КонецЕсли;

		Если ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
			
			Для каждого КлючЗначение Из ПараметрыЗапроса Цикл
				
				ЗначениеПараметра = КлючЗначение.Значение;
				
				// Если параметр - описание объекта, конвертируем обратно в ссылку
				Если ТипЗнч(ЗначениеПараметра) = Тип("Структура") 
					И ЗначениеПараметра.Свойство("_objectRef") 
					И ЗначениеПараметра._objectRef = Истина Тогда
					
					ЗначениеПараметра = ОбъектИнформационнойБазы(ЗначениеПараметра);
					
				КонецЕсли;
				
				Запрос.УстановитьПараметр(КлючЗначение.Ключ, ЗначениеПараметра);
				
			КонецЦикла;
			
		КонецЕсли;

		РезультатЗапроса = Запрос.Выполнить();
		МассивКолонок = ПолучитьКолонкиРезультата(РезультатЗапроса);
		Выборка = РезультатЗапроса.Выбрать();
		СтрокиИСостояние = СобратьСтроки(Выборка, МассивКолонок, Предел);

		Результат = Новый Структура;
		Результат.Вставить("success", Истина);

		Сообщение = ?(СтрокиИСостояние.truncated, "Выборка усечена по лимиту " + Строка(Предел), "Запрос выполнен успешно");
		
		Результат.Вставить("message", Сообщение);
		Результат.Вставить("truncated", СтрокиИСостояние.truncated);
		Результат.Вставить("limit", Предел);
		Результат.Вставить("columns", МассивКолонок);
		Результат.Вставить("rows", СтрокиИСостояние.rows);

		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);

	Исключение
		Результат = Новый Структура;
		Результат.Вставить("success", Ложь);
		
		ТекстОшибки = ОписаниеОшибки();
		ПодсказкаИнструмент = Символы.ПС + Символы.ПС 
			+ " HINT: При ошибке запроса проверьте:" + Символы.ПС
			+ "1) Структуру объектов метаданных через get_metadata_structure (правильность имен таблиц, полей, табличных частей)" + Символы.ПС
			+ "2) Формат передаваемых параметров (объекты должны иметь структуру {_objectRef, УникальныйИдентификатор, ТипОбъекта})" + Символы.ПС
			+ "3) Если используете навигационные ссылки - сначала преобразуйте их через parse_nav_link";
		
		Результат.Вставить("message", ТекстОшибки + ПодсказкаИнструмент);
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
	КонецПопытки;
	
КонецФункции

// Возвращает массив описаний колонок результата запроса.
// Параметры:
//   РезультатЗапроса - РезультатЗапроса - Результат выполнения запроса.
// Возвращаемое значение:
//   Массив - Элементы представляют структуры с полем name.
Функция ПолучитьКолонкиРезультата(РезультатЗапроса)
	
	МассивКолонок = Новый Массив;
	Для каждого Колонка Из РезультатЗапроса.Колонки Цикл
		СтруктураКолонки = Новый Структура;
		СтруктураКолонки.Вставить("name", Колонка.Имя);
		МассивКолонок.Добавить(СтруктураКолонки);
	КонецЦикла;
	
	Возврат МассивКолонок;
	
КонецФункции

// Собирает строки выборки с учетом ограничения.
// Параметры:
//   Выборка - ВыборкаИзРезультатаЗапроса - Результат выполнения запроса.
//   Колонки - Массив - Описания колонок результата.
//   Предел - Число - Максимальное количество строк.
// Возвращаемое значение:
//   Структура - Поля rows (массив структур строк) и truncated (Булево).
Функция СобратьСтроки(Выборка, Колонки, Предел)
	
	МассивСтрок = Новый Массив;
	Усечено = Ложь;

	Пока Выборка.Следующий() Цикл
		Если МассивСтрок.Количество() >= Предел Тогда
			Усечено = Истина;
			Прервать;
		КонецЕсли;

		Строка = Новый Структура;
		
		Для каждого Колонка Из Колонки Цикл
			
			ЗначениеПоля = Выборка[Колонка.name];
			
			// Автоматическая конвертация ссылочных типов в описания объектов
			Если ЗначениеЗаполнено(ЗначениеПоля) И ЭтоСсылка(ТипЗнч(ЗначениеПоля)) Тогда
				Строка.Вставить(Колонка.name, ОписаниеОбъектаПоСсылке(ЗначениеПоля));
			Иначе
				Строка.Вставить(Колонка.name, ЗначениеПоля);
			КонецЕсли;
			
		КонецЦикла;
		
		МассивСтрок.Добавить(Строка);
	КонецЦикла;

	Возврат Новый Структура("rows, truncated", МассивСтрок, Усечено);
	
КонецФункции

// Обработка преобразования навигационной ссылки в описание объекта.
// Параметры:
//   НавСсылка - Строка - Навигационная ссылка формата e1cib/data/...
// Возвращаемое значение:
//   Строка - JSON-строка с описанием объекта или ошибкой.
Функция ОбработатьПреобразованиеНавСсылки(НавСсылка)
	
	Попытка
		
		ОписаниеОбъекта = ОписаниеОбъектаПоНавигационнойСсылке(НавСсылка);
		
		Если ОписаниеОбъекта = Неопределено Тогда
			
			Результат = Новый Структура;
			Результат.Вставить("success", Ложь);
			Результат.Вставить("message", "Не удалось распарсить навигационную ссылку. Проверьте формат.");
			
			Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
			
		КонецЕсли;
		
		Результат = Новый Структура;
		Результат.Вставить("success", Истина);
		Результат.Вставить("object", ОписаниеОбъекта);
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
		
	Исключение
		
		Результат = Новый Структура;
		Результат.Вставить("success", Ложь);
		Результат.Вставить("message", ОписаниеОшибки());
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
		
	КонецПопытки;
	
КонецФункции

// Получение навигационной ссылки по описанию объекта.
// Параметры:
//   ОписаниеОбъекта - Структура - Описание объекта с полями УникальныйИдентификатор, ТипОбъекта.
// Возвращаемое значение:
//   Строка - JSON-строка с навигационной ссылкой или ошибкой.
Функция ПолучитьНавСсылкуПоОписанию(ОписаниеОбъекта)
	
	Попытка
		
		НавСсылка = НавигационнаяСсылкаПоОписаниюОбъекта(ОписаниеОбъекта);
		
		Результат = Новый Структура;
		Результат.Вставить("success", Истина);
		Результат.Вставить("navLink", НавСсылка);
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
		
	Исключение
		
		Результат = Новый Структура;
		Результат.Вставить("success", Ложь);
		Результат.Вставить("message", ОписаниеОшибки());
		
		Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
		
	КонецПопытки;
	
КонецФункции

// Функция - Объект информационной базы
//
// Параметры:
//  ОписаниеОбъекта		 - Структура 	- Структура с уникальными идентификатором и типом объекта
//  ПроверятьЗаполнение	 - Булево 		- Признак необходимости проверять заполненность элемента
// 
// Возвращаемое значение:
//  ПроизвольнаяСсылка - Ссылка на объект информационной базы
//
Функция ОбъектИнформационнойБазы(Знач ОписаниеОбъекта, ПроверятьЗаполнение = Истина)
	
	Ссылка = Неопределено;

	// Строковое представление ссылки может использоваться в ключах структур и соответствий
	Если ТипЗнч(ОписаниеОбъекта) = Тип("Строка") Тогда
		ЧастиСтроки 				= СтрРазделить(ОписаниеОбъекта, ";");
		ОжидаемоеКоличествоЧастей 	= 2;
		Если ЧастиСтроки.Количество() <> ОжидаемоеКоличествоЧастей Тогда
			ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Ошибка формата объекта информационной базы. Операция прервана.'"));	
		КонецЕсли;
			
		ОписаниеОбъекта = Новый Структура;
		ОписаниеОбъекта.Вставить("УникальныйИдентификатор", ЧастиСтроки[0]);
		ОписаниеОбъекта.Вставить("ТипОбъекта",				ЧастиСтроки[1]);
	КонецЕсли;	
		
	Если Не ЗначениеЗаполнено(ОписаниеОбъекта.ТипОбъекта) И Не ЗначениеЗаполнено(ОписаниеОбъекта.УникальныйИдентификатор) Тогда
		Если ПроверятьЗаполнение Тогда
			ВызватьИсключение СтрШаблон(
				НСтр("ru = 'Попытка получить объект ИБ по незаполненым параметрам.
				|ТипОбъекта: %1
				|УникальныйИдентификатор: %2'"),
				ОписаниеОбъекта.ТипОбъекта,
				ОписаниеОбъекта.УникальныйИдентификатор);
		Иначе
			Возврат Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	ОписаниеТипа 	= Новый ОписаниеТипов(ОписаниеОбъекта.ТипОбъекта);
	ПустоеЗначение 	= ОписаниеТипа.ПривестиЗначение();
	МенеджерОбъекта = МенеджерОбъектаПоСсылке(ПустоеЗначение);
	
	Если ЭтоУникальныйИдентификатор(ОписаниеОбъекта.УникальныйИдентификатор) Тогда
		Ссылка = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.УникальныйИдентификатор));
	Иначе // возможно, это имя предопределенного элемента или перечисление
		Попытка
			Ссылка = МенеджерОбъекта[ОписаниеОбъекта.УникальныйИдентификатор];
		Исключение
			ВызватьИсключение СтрШаблон(
				НСтр("ru = 'Нет значения ""%1"" среди значений типа ""%2""'"),
				ОписаниеОбъекта.УникальныйИдентификатор,
				ОписаниеОбъекта.ТипОбъекта);
		КонецПопытки;
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

// Функция - Описание объекта
//
// Параметры:
//  СсылкаНаОбъект			 - ПроизвольнаяСсылка - Ссылка на объект базы данных
// 
// Возвращаемое значение:
//  Структура, Строка - Структура описывающая объект
//
Функция ОписаниеОбъектаПоСсылке(СсылкаНаОбъект)
	
	УникальныйИдентификатор = XMLСтрока(СсылкаНаОбъект);
	ТипОбъекта 				= СтроковоеПредставлениеТипа(ТипЗнч(СсылкаНаОбъект));
	Представление 			= Строка(СсылкаНаОбъект);
	
	ОписаниеОбъекта = Новый Структура;
	ОписаниеОбъекта.Вставить("_objectRef"				, Истина);
	ОписаниеОбъекта.Вставить("УникальныйИдентификатор"	, УникальныйИдентификатор);
	ОписаниеОбъекта.Вставить("ТипОбъекта"				, ТипОбъекта);
	ОписаниеОбъекта.Вставить("Представление"			, Представление);
	
	Возврат ОписаниеОбъекта;
	
КонецФункции

Функция НавигационнаяСсылкаПоОписаниюОбъекта(ОписаниеОбъекта)
	
	СсылкаНаОбъект = ОбъектИнформационнойБазы(ОписаниеОбъекта);
	
	Возврат ПолучитьНавигационнуюСсылку(СсылкаНаОбъект);
	
КонецФункции

Функция ОписаниеОбъектаПоНавигационнойСсылке(НС)
	
	ОписаниеОбъекта = Неопределено;
	
	НС = РаскодироватьСтроку(НС, СпособКодированияСтроки.КодировкаURL);
	
	ПерваяТочка = СтрНайти(НС, "e1cib/data/");
	
	Если ПерваяТочка = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если СтрНайти(НС, "?ref=") > 0 Тогда
		ВтораяТочка = СтрНайти(НС, "?ref=");
		ПредставлениеТипа = Сред(НС, ПерваяТочка + 11, ВтораяТочка - ПерваяТочка - 11);
		ШаблонЗначения = ЗначениеВСтрокуВнутр(ПредопределенноеЗначение(ПредставлениеТипа + ".ПустаяСсылка"));
		ЗначениеСсылки = СтрЗаменить(ШаблонЗначения, "00000000000000000000000000000000", Сред(НС, ВтораяТочка + 5));
		
		СсылкаНаОбъект = ЗначениеИзСтрокиВнутр(ЗначениеСсылки);
		
		ОписаниеОбъекта = ОписаниеОбъектаПоСсылке(СсылкаНаОбъект);
		
	Иначе
		Возврат Неопределено;
		
	КонецЕсли;
	
	Возврат ОписаниеОбъекта;
	
КонецФункции

// Возвращает строковое представление типа, например, "СправочникСсылка.ИмяОбъекта", "ДокументСсылка.ИмяОбъекта".
// Для остальных типов приводит тип к строке, например "Число".
//
// Параметры:
//  Тип - Тип - для которого надо получить представление.
//
// Возвращаемое значение:
//  Строка
//
Функция СтроковоеПредставлениеТипа(Тип) Экспорт
	
	Представление = "";
	
	Если ЭтоСсылка(Тип) Тогда
	
		ПолноеИмя = Метаданные.НайтиПоТипу(Тип).ПолноеИмя();
		ИмяОбъекта = СтрРазделить(ПолноеИмя, ".")[1];
		
		Если Справочники.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "СправочникСсылка";
		
		ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ДокументСсылка";
		
		ИначеЕсли БизнесПроцессы.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "БизнесПроцессСсылка";
		
		ИначеЕсли БизнесПроцессы.ТипВсеСсылкиТочекМаршрутаБизнесПроцессов().СодержитТип(Тип) Тогда
			Представление = "ТочкаМаршрутаБизнесПроцессаСсылка";
		
		ИначеЕсли ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ПланВидовХарактеристикСсылка";
		
		ИначеЕсли ПланыСчетов.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ПланСчетовСсылка";
		
		ИначеЕсли ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ПланВидовРасчетаСсылка";
		
		ИначеЕсли Задачи.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ЗадачаСсылка";
		
		ИначеЕсли ПланыОбмена.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ПланОбменаСсылка";
		
		ИначеЕсли Перечисления.ТипВсеСсылки().СодержитТип(Тип) Тогда
			Представление = "ПеречислениеСсылка";
		
		КонецЕсли;
		
		Результат = ?(Представление = "", Представление, Представление + "." + ИмяОбъекта);
		
	ИначеЕсли Тип = Тип("Неопределено") Тогда
		Результат = "Неопределено";
		
	ИначеЕсли Тип = Тип("Строка") Тогда
		Результат = "Строка";

	ИначеЕсли Тип = Тип("Число") Тогда
		Результат = "Число";

	ИначеЕсли Тип = Тип("Булево") Тогда
		Результат = "Булево";

	ИначеЕсли Тип = Тип("Дата") Тогда
		Результат = "Дата";
	
	Иначе
		
		Результат = Строка(Тип);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает менеджер объекта по ссылке на объект.
// Ограничение: не обрабатываются точки маршрутов бизнес-процессов.
// См. также ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени.
//
// Параметры:
//  Ссылка - ЛюбаяСсылка - объект, менеджер которого требуется получить.
//
// Возвращаемое значение:
//  СправочникМенеджер, ДокументМенеджер, ОбработкаМенеджер, РегистрСведенийМенеджер - менеджер объекта.
//
// Пример:
//  МенеджерСправочника = ОбщегоНазначения.МенеджерОбъектаПоСсылке(СсылкаНаОрганизацию);
//  ПустаяСсылка = МенеджерСправочника.ПустаяСсылка();
//
Функция МенеджерОбъектаПоСсылке(Ссылка)
	
	ИмяОбъекта = Ссылка.Метаданные().Имя;
	ТипСсылки = ТипЗнч(Ссылка);
	
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат Справочники[ИмяОбъекта];
		
	ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат Документы[ИмяОбъекта];
		
	ИначеЕсли БизнесПроцессы.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат БизнесПроцессы[ИмяОбъекта];
		
	ИначеЕсли ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат ПланыВидовХарактеристик[ИмяОбъекта];
		
	ИначеЕсли ПланыСчетов.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат ПланыСчетов[ИмяОбъекта];
		
	ИначеЕсли ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат ПланыВидовРасчета[ИмяОбъекта];
		
	ИначеЕсли Задачи.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат Задачи[ИмяОбъекта];
		
	ИначеЕсли ПланыОбмена.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат ПланыОбмена[ИмяОбъекта];
		
	ИначеЕсли Перечисления.ТипВсеСсылки().СодержитТип(ТипСсылки) Тогда
		Возврат Перечисления[ИмяОбъекта];
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Проверяет, является ли строка уникальным идентификатором.
// В качестве уникального идентификатора предполагается строка вида
// "XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX", где X = [0..9,a..f].
//
// Параметры:
//  Значение - Строка - проверяемая строка.
//
// Возвращаемое значение:
//  Булево - Истина, если переданная строка является уникальным идентификатором.
//
Функция ЭтоУникальныйИдентификатор(Значение)
	
	Возврат СтрДлина(Значение) = 36
		И СтрЧислоВхождений(Значение, "-") = 4
		И Сред(Значение, 9, 1) = "-"
		И Сред(Значение, 14, 1) = "-"
		И Сред(Значение, 19, 1) = "-"
		И Сред(Значение, 24, 1) = "-"
		И СтрРазделить(Значение, "-0123456789abcdefABCDEF", Ложь).Количество() = 0;
	
КонецФункции

// Проверка того, что переданный тип является ссылочным типом данных.
// Для типа "Неопределено" возвращается Ложь.
//
// Параметры:
//  ПроверяемыйТип - Тип - для проверки на ссылочный тип данных.
//
// Возвращаемое значение:
//  Булево - Истина, если это ссылка.
//
Функция ЭтоСсылка(ПроверяемыйТип)
	
	Возврат ПроверяемыйТип <> Тип("Неопределено") И ОписаниеТипаВсеСсылки().СодержитТип(ПроверяемыйТип);
	
КонецФункции

Функция ОписаниеТипаВсеСсылки()
	
	Возврат Новый ОписаниеТипов(Новый ОписаниеТипов(Новый ОписаниеТипов(Новый ОписаниеТипов(Новый ОписаниеТипов(
		Новый ОписаниеТипов(Новый ОписаниеТипов(Новый ОписаниеТипов(Новый ОписаниеТипов(
			Справочники.ТипВсеСсылки(),
			Документы.ТипВсеСсылки().Типы()),
			ПланыОбмена.ТипВсеСсылки().Типы()),
			Перечисления.ТипВсеСсылки().Типы()),
			ПланыВидовХарактеристик.ТипВсеСсылки().Типы()),
			ПланыСчетов.ТипВсеСсылки().Типы()),
			ПланыВидовРасчета.ТипВсеСсылки().Типы()),
			БизнесПроцессы.ТипВсеСсылки().Типы()),
			БизнесПроцессы.ТипВсеСсылкиТочекМаршрутаБизнесПроцессов().Типы()),
			Задачи.ТипВсеСсылки().Типы());
	
КонецФункции

#КонецОбласти