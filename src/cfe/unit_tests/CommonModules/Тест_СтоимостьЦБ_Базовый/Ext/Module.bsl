// Тест-модуль YaxUnit: Тест_СтоимостьЦБ_Базовый
// Покрывает сценарии T-14, T-15, T-16 из Test Plan (SPEC-007).
// T-14: Отчет СтоимостьЦБ создан и доступен (R-09, AC-05).
// T-15: Параметр ДатаОтчета присутствует (R-10).
// T-16: Все 9 колонок присутствуют в наборе данных СКД (R-11, AC-08).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("СтоимостьЦБ_Базовый")
			.ДобавитьСерверныйТест("ТестТ14ОтчетСуществует")
			.ДобавитьСерверныйТест("ТестТ15ПараметрДатаОтчетаПрисутствует")
			.ДобавитьСерверныйТест("ТестТ16ВсеКолонкиПрисутствуют");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-14: Отчет СтоимостьЦБ создан и доступен.
// Связь: R-09, AC-05.
//
Процедура ТестТ14ОтчетСуществует() Экспорт

	// Arrange: ничего не требуется

	// Act: проверяем наличие объекта в метаданных
	МетаданныеОтчета = Метаданные.Отчеты.Найти("СтоимостьЦБ");

	// Assert: объект метаданных должен существовать
	ЮТест.ОжидаетЧто(МетаданныеОтчета)
		.НеРавно(Неопределено, "Метаданные.Отчеты.СтоимостьЦБ должен существовать");

	// Дополнительно: отчет должен создаваться без исключений
	ВызваноИсключение = Ложь;
	Попытка
		ОтчетОбъект = Отчеты.СтоимостьЦБ.Создать();
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Создание экземпляра Отчеты.СтоимостьЦБ.Создать() не должно вызывать исключение");

КонецПроцедуры

// T-15: Параметр ДатаОтчета присутствует в СКД.
// Связь: R-10, AC-06.
//
Процедура ТестТ15ПараметрДатаОтчетаПрисутствует() Экспорт

	// Arrange: получаем объект отчета и схему
	ОтчетОбъект = Отчеты.СтоимостьЦБ.Создать();
	СхемаКД = ОтчетОбъект.СхемаКомпоновкиДанных;

	// Act: получаем параметры схемы
	ПараметрыСхемы = СхемаКД.Параметры;

	ИменаПараметров = Новый Массив;
	Для Каждого Параметр Из ПараметрыСхемы Цикл
		ИменаПараметров.Добавить(Параметр.Имя);
	КонецЦикла;

	// Assert: параметр ДатаОтчета должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("ДатаОтчета", "Параметр ДатаОтчета должен присутствовать в СКД");

КонецПроцедуры

// T-16: Все 9 колонок присутствуют в СКД.
// Связь: R-11, AC-08.
// В строке результата должны присутствовать: ЦеннаяБумага, Партия, Количество,
// Стоимость, Переоценка, Затраты, НКДПолученный, НКДНакопленный, ИтоговаяСтоимость.
//
Процедура ТестТ16ВсеКолонкиПрисутствуют() Экспорт

	// Arrange: получаем схему данных отчета
	ОтчетОбъект = Отчеты.СтоимостьЦБ.Создать();
	СхемаКД = ОтчетОбъект.СхемаКомпоновкиДанных;

	// Получаем доступные поля из наборов данных.
	// Свойство "Поле" содержит имя поля набора данных (совпадает с именем ресурса/измерения регистра).
	// Свойство "ПутьКДанным" содержит путь в настройках СКД (может отличаться от имени поля).
	ДоступныеПоля = Новый Массив;
	Для Каждого НаборДанных Из СхемаКД.НаборыДанных Цикл
		Для Каждого ОписаниеПоля Из НаборДанных.Поля Цикл
			ДоступныеПоля.Добавить(ОписаниеПоля.Поле);
			// Также добавляем ПутьКДанным на случай если имя отличается
			Если ОписаниеПоля.ПутьКДанным <> ОписаниеПоля.Поле Тогда
				ДоступныеПоля.Добавить(ОписаниеПоля.ПутьКДанным);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	// Добавляем вычисляемые поля.
	// Для вычисляемых полей имя задаётся через ПутьКДанным (свойство Имя отсутствует).
	Для Каждого ВычПоле Из СхемаКД.ВычисляемыеПоля Цикл
		ДоступныеПоля.Добавить(ВычПоле.ПутьКДанным);
	КонецЦикла;

	// Assert: каждая из 9 обязательных колонок должна присутствовать
	ОбязательныеКолонки = Новый Массив;
	ОбязательныеКолонки.Добавить("ЦеннаяБумага");
	ОбязательныеКолонки.Добавить("Партия");
	ОбязательныеКолонки.Добавить("Количество");
	ОбязательныеКолонки.Добавить("Стоимость");
	ОбязательныеКолонки.Добавить("Переоценка");
	ОбязательныеКолонки.Добавить("Затраты");
	ОбязательныеКолонки.Добавить("НКДПолученный");
	ОбязательныеКолонки.Добавить("НКДНакопленный");
	ОбязательныеКолонки.Добавить("ИтоговаяСтоимость");

	Для Каждого ИмяКолонки Из ОбязательныеКолонки Цикл
		ЮТест.ОжидаетЧто(ДоступныеПоля)
			.Содержит(ИмяКолонки, СтрШаблон("Колонка '%1' должна присутствовать в СКД СтоимостьЦБ", ИмяКолонки));
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
