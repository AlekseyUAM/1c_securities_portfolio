// Тест-модуль YaxUnit: Тест_ФинансовыйРезультат_Базовый
// Покрывает сценарии T-08, T-09, T-10 из Test Plan (SPEC-007).
// T-08: Отчет ФинансовыйРезультат создан и доступен (R-05, AC-03).
// T-09: Параметры НачалоПериода, КонецПериода присутствуют (R-06).
// T-10: Группировка по ЦеннаяБумага присутствует в СКД (R-07, AC-04).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("ФинансовыйРезультат_Базовый")
			.ДобавитьСерверныйТест("ТестТ08ОтчетСуществует")
			.ДобавитьСерверныйТест("ТестТ09ПараметрыПрисутствуют")
			.ДобавитьСерверныйТест("ТестТ10ГруппировкаПоЦенныеБумаги");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-08: Отчет ФинансовыйРезультат создан и доступен.
// Связь: R-05, AC-03.
//
Процедура ТестТ08ОтчетСуществует() Экспорт

	// Arrange: ничего не требуется

	// Act: проверяем наличие объекта в метаданных
	МетаданныеОтчета = Метаданные.Отчеты.Найти("ФинансовыйРезультат");

	// Assert: объект метаданных должен существовать
	ЮТест.ОжидаетЧто(МетаданныеОтчета)
		.НеРавно(Неопределено, "Метаданные.Отчеты.ФинансовыйРезультат должен существовать");

	// Дополнительно: отчет должен создаваться без исключений
	ВызваноИсключение = Ложь;
	Попытка
		ОтчетОбъект = Отчеты.ФинансовыйРезультат.Создать();
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Создание экземпляра Отчеты.ФинансовыйРезультат.Создать() не должно вызывать исключение");

КонецПроцедуры

// T-09: Параметры НачалоПериода и КонецПериода присутствуют в СКД отчета.
// Связь: R-06, AC-04.
//
Процедура ТестТ09ПараметрыПрисутствуют() Экспорт

	// Arrange: получаем объект отчета и схему
	ОтчетОбъект = Отчеты.ФинансовыйРезультат.Создать();
	СхемаКД = ОтчетОбъект.СхемаКомпоновкиДанных;

	// Act: получаем параметры схемы
	ПараметрыСхемы = СхемаКД.Параметры;

	ИменаПараметров = Новый Массив;
	Для Каждого Параметр Из ПараметрыСхемы Цикл
		ИменаПараметров.Добавить(Параметр.Имя);
	КонецЦикла;

	// Assert: параметр НачалоПериода должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("НачалоПериода", "Параметр НачалоПериода должен присутствовать в СКД");

	// Assert: параметр КонецПериода должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("КонецПериода", "Параметр КонецПериода должен присутствовать в СКД");

КонецПроцедуры

// T-10: Группировка по ЦеннаяБумага присутствует в структуре СКД.
// Связь: R-07, AC-04.
// Тест проверяет наличие группировки ЦеннаяБумага в структуре отчета.
//
Процедура ТестТ10ГруппировкаПоЦенныеБумаги() Экспорт

	// Arrange: получаем объект отчета и схему
	ОтчетОбъект = Отчеты.ФинансовыйРезультат.Создать();
	СхемаКД = ОтчетОбъект.СхемаКомпоновкиДанных;

	// Act: получаем структуру (группировки)
	Структура = СхемаКД.НастройкиПоУмолчанию.Структура;

	// Assert: в структуре должна быть хотя бы одна группировка (содержит ЦеннаяБумага согласно R-07).
	// Проверяем факт наличия группировок в структуре — детали настроены в метаданных СКД.
	ЮТест.ОжидаетЧто(Структура.Количество())
		.Больше(0, "Структура СКД отчета ФинансовыйРезультат должна содержать группировки по ЦеннаяБумага");

КонецПроцедуры

#КонецОбласти
