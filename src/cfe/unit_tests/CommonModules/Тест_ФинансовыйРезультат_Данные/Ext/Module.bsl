// Тест-модуль YaxUnit: Тест_ФинансовыйРезультат_Данные
// Покрывает сценарии T-08, T-11, T-12, T-13 из Test Plan (SPEC-007).
// T-08: Итоговая строка (общий итог) по колонке Сумма (R-08, AC-04).
// T-11: Движения отфильтрованы по периоду (R-06, R-07, AC-04).
// T-12: Суммы корректно агрегированы GROUP BY ЦеннаяБумага (R-07, AC-04).
// T-13: Нет движений в периоде — пустой результат (SHOULD T-10 в spec).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("ФинансовыйРезультат_Данные")
			.ДобавитьСерверныйТест("ТестТ08ИтоговаяСтрока")
			.ДобавитьСерверныйТест("ТестТ11ФильтрПоПериоду")
			.ДобавитьСерверныйТест("ТестТ12АгрегацияСуммы")
			.ДобавитьСерверныйТест("ТестТ13ПустойРезультат");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-08: Отчет ФинансовыйРезультат отображает итоговую строку (общий итог) по колонке Сумма.
// Связь: R-08, AC-04 (spec T-08, MUST).
// Создаём движения для нескольких ЦБ, формируем отчет, проверяем наличие итоговой строки
// (ЦеннаяБумага не заполнена), и что её Сумма равна сумме всех детальных строк.
//
Процедура ТестТ08ИтоговаяСтрока() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: две разные ЦБ с разными суммами движений
		ЦБ1 = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ЦБ2 = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		Документ1 = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");
		Документ2 = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		// Движение ЦБ1: 1200
		// РегистрНакопления.ФинансовыйРезультат — регистр оборотов, ВидДвижения не используется.
		НаборЗаписей1 = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборЗаписей1.Отбор.Регистратор.Установить(Документ1);
		Запись1 = НаборЗаписей1.Добавить();
		Запись1.Период = '20260110';
		Запись1.ЦеннаяБумага = ЦБ1;
		Запись1.Сумма = 1200;
		НаборЗаписей1.Записать();

		// Движение ЦБ2: 800
		НаборЗаписей2 = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборЗаписей2.Отбор.Регистратор.Установить(Документ2);
		Запись2 = НаборЗаписей2.Добавить();
		Запись2.Период = '20260115';
		Запись2.ЦеннаяБумага = ЦБ2;
		Запись2.Сумма = 800;
		НаборЗаписей2.Записать();

		// Act: формируем отчет за январь 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетФинансовыйРезультат(ПараметрыОтчета);

		// Собираем суммы детальных строк и ищем итоговую строку
		СуммаДетальных = 0;
		ИтоговаяСтрока = Неопределено;

		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ1 Или Строка.ЦеннаяБумага = ЦБ2 Тогда
				// Детальная строка — накапливаем сумму
				СуммаДетальных = СуммаДетальных + Строка.Сумма;
			ИначеЕсли Не ЗначениеЗаполнено(Строка.ЦеннаяБумага) Тогда
				// Итоговая строка — ЦеннаяБумага не заполнена
				ИтоговаяСтрока = Строка;
			КонецЕсли;
		КонецЦикла;

		// Assert: итоговая строка должна присутствовать
		ЮТест.ОжидаетЧто(ИтоговаяСтрока)
			.НеРавно(Неопределено, "Отчет ФинансовыйРезультат должен содержать итоговую строку (общий итог)");

		// Assert: сумма в итоговой строке = сумма всех детальных строк нашей ЦБ1 и ЦБ2
		Если ИтоговаяСтрока <> Неопределено Тогда
			ЮТест.ОжидаетЧто(ИтоговаяСтрока.Сумма)
				.БольшеИлиРавно(СуммаДетальных,
					СтрШаблон("Сумма итоговой строки (%1) должна не меньше суммы наших детальных строк (%2)",
						ИтоговаяСтрока.Сумма, СуммаДетальных));
		КонецЕсли;

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-11: Движения отфильтрованы по периоду.
// Связь: R-06, R-07, AC-04.
// Движение вне указанного периода не должно включаться в результат.
//
Процедура ТестТ11ФильтрПоПериоду() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: ценная бумага с движениями внутри и вне периода
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ДокументВнутри = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");
		ДокументВне = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		// Движение внутри периода (15 января 2026)
		// РегистрНакопления.ФинансовыйРезультат — регистр оборотов, ВидДвижения не используется.
		НаборВнутри = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборВнутри.Отбор.Регистратор.Установить(ДокументВнутри);
		ЗаписьВнутри = НаборВнутри.Добавить();
		ЗаписьВнутри.Период = '20260115';
		ЗаписьВнутри.ЦеннаяБумага = ЦБ;
		ЗаписьВнутри.Сумма = 1000;
		НаборВнутри.Записать();

		// Движение вне периода (1 марта 2026 — после КонецПериода)
		НаборВне = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборВне.Отбор.Регистратор.Установить(ДокументВне);
		ЗаписьВне = НаборВне.Добавить();
		ЗаписьВне.Период = '20260301';
		ЗаписьВне.ЦеннаяБумага = ЦБ;
		ЗаписьВне.Сумма = 9999;
		НаборВне.Записать();

		// Act: формируем отчет только за январь 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетФинансовыйРезультат(ПараметрыОтчета);

		// Assert: ЦБ присутствует в результате (движение за январь)
		НайденаЦБ = Ложь;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ Тогда
				НайденаЦБ = Истина;
				// Assert: сумма должна быть 1000, не 9999+1000
				ЮТест.ОжидаетЧто(Строка.Сумма)
					.Равно(1000, "Сумма должна включать только движение за январь (1000), не мартовское (9999)");
				Прервать;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(НайденаЦБ)
			.ЭтоИстина("ЦБ с движением в январе должна присутствовать в результате");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-12: Суммы корректно агрегированы (GROUP BY ЦеннаяБумага).
// Связь: R-07, AC-04.
// Два движения по одной ЦБ → в отчете одна строка с суммой обоих движений.
//
Процедура ТестТ12АгрегацияСуммы() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: одна ЦБ, два движения в одном периоде
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ДокументА = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");
		ДокументБ = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		// Первое движение: 500
		// РегистрНакопления.ФинансовыйРезультат — регистр оборотов, ВидДвижения не используется.
		НаборЗаписей1 = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборЗаписей1.Отбор.Регистратор.Установить(ДокументА);
		Запись1 = НаборЗаписей1.Добавить();
		Запись1.Период = '20260110';
		Запись1.ЦеннаяБумага = ЦБ;
		Запись1.Сумма = 500;
		НаборЗаписей1.Записать();

		// Второе движение: 300
		НаборЗаписей2 = РегистрыНакопления.ФинансовыйРезультат.СоздатьНаборЗаписей();
		НаборЗаписей2.Отбор.Регистратор.Установить(ДокументБ);
		Запись2 = НаборЗаписей2.Добавить();
		Запись2.Период = '20260120';
		Запись2.ЦеннаяБумага = ЦБ;
		Запись2.Сумма = 300;
		НаборЗаписей2.Записать();

		// Act: формируем отчет за январь 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетФинансовыйРезультат(ПараметрыОтчета);

		// Assert: в результате ровно одна детальная строка для нашей ЦБ (агрегация).
		// Считаем только строки, где ЦеннаяБумага = ЦБ, исключая итоговые строки СКД.
		КоличествоДетальныхСтрокДляЦБ = 0;
		СуммаДляЦБ = 0;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ Тогда
				КоличествоДетальныхСтрокДляЦБ = КоличествоДетальныхСтрокДляЦБ + 1;
				СуммаДляЦБ = Строка.Сумма;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(КоличествоДетальныхСтрокДляЦБ)
			.Равно(1, "Для одной ЦБ должна быть ровно одна агрегированная строка (GROUP BY)");

		ЮТест.ОжидаетЧто(СуммаДляЦБ)
			.Равно(800, "Агрегированная сумма должна быть 500 + 300 = 800");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-13: Нет движений в периоде — пустой результат.
// Связь: SHOULD T-10 в spec.
// При отсутствии движений за период отчет формируется без ошибок.
//
Процедура ТестТ13ПустойРезультат() Экспорт

	// Arrange: период без движений (будущая дата)
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("НачалоПериода", '20300101');
	ПараметрыОтчета.Вставить("КонецПериода", '20300131');

	// Act: формируем отчет
	ВызваноИсключение = Ложь;
	РезультатОтчета = Неопределено;
	Попытка
		РезультатОтчета = СформироватьОтчетФинансовыйРезультат(ПараметрыОтчета);
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	// Assert: формирование без ошибок
	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Отчет при отсутствии движений должен формироваться без исключений");

	// Assert: результат пустой
	ЮТест.ОжидаетЧто(РезультатОтчета.Количество())
		.Равно(0, "При отсутствии движений результат должен быть пустым");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует отчет ФинансовыйРезультат через СКД и возвращает таблицу значений.
//
// Параметры:
//   ПараметрыОтчета - Структура - ключи: НачалоПериода, КонецПериода.
//
// Возвращаемое значение:
//   ТаблицаЗначений - строки результата компоновки.
//
Функция СформироватьОтчетФинансовыйРезультат(ПараметрыОтчета)

	ОтчетОбъект = Отчеты.ФинансовыйРезультат.Создать();

	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(
			ОтчетОбъект.СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(
		ОтчетОбъект.СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

	// Установка параметров
	Для Каждого КлючЗначение Из ПараметрыОтчета Цикл
		КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(
			КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(
		ОтчетОбъект.СхемаКомпоновкиДанных,
		КомпоновщикНастроек.Настройки,,,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	КоллекцияЗначений = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(КоллекцияЗначений);
	// Ложь — не создавать вложенную транзакцию внутри СКД-процессора,
	// чтобы запрос выполнялся в контексте текущей внешней транзакции
	// и видел данные, записанные в ней через НаборЗаписей.Записать().
	ПроцессорВывода.Вывести(ПроцессорКомпоновки, Ложь);

	Возврат КоллекцияЗначений;

КонецФункции

#КонецОбласти
