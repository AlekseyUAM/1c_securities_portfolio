		ЮТест.ОжидаетЧто(ТаблицаФР[0].Сумма).Равно(20, "Сумма = 2 * 10 = 20 после перепроведения");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

