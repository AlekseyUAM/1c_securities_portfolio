// TP-05: Нет остатков → Отказ
Процедура ТестНетОстатковОтказ() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Куп05");

		ДокПогашение = Документы.ПогашениеКупонов.СоздатьДокумент();
		ДокПогашение.Дата = ТекущаяДатаСеанса();
		ДокПогашение.ЦеннаяБумага = ЦеннаяБумага;
		ДокПогашение.НКД = 1;

		ВызваноИсключение = Ложь;
		Попытка
			ДокПогашение.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ВызваноИсключение = Истина;
		КонецПопытки;

		ЮТест.ОжидаетЧто(ВызваноИсключение).ЭтоИстина("проведение отменено: нет остатков");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// Недостаточно НКД → Отказ
