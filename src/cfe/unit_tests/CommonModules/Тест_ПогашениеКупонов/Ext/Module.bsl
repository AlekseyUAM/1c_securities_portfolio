		ДокПогашение.НКД = 1;

		ВызваноИсключение = Ложь;
		Попытка
			ДокПогашение.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ВызваноИсключение = Истина;
		КонецПопытки;

		ЮТест.ОжидаетЧто(ВызваноИсключение).ЭтоИстина("проведение отменено: недостаточно НКД");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

