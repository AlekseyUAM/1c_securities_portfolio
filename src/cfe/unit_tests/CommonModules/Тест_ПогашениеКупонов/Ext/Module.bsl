		// Поступление с НКД = 5 → НКДПолученный = 5
		СоздатьИПровестиПоступление(ЦеннаяБумага, 10, 100, 5, 0);

		// Пытаемся погасить 1 на штуку → 10 > 5
		ДокПогашение = Документы.ПогашениеКупонов.СоздатьДокумент();
		ДокПогашение.Дата = ТекущаяДатаСеанса();
