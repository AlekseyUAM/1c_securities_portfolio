#Область ПрограммныйИнтерфейс

Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("БазовоеПогашение")
			.ДобавитьСерверныйТест("ТестОднаПартияПогашение")
			.ДобавитьСерверныйТест("ТестДвеПартииПогашение")
		.ДобавитьТестовыйНабор("НулевыеРесурсы")
			.ДобавитьСерверныйТест("ТестПрочиеРесурсыНулевые")
		.ДобавитьТестовыйНабор("НетОстатков")
			.ДобавитьСерверныйТест("ТестНетОстатковОтказ")
		.ДобавитьТестовыйНабор("НедостаточноНКД")
			.ДобавитьСерверныйТест("ТестНедостаточноНКДОтказ")
		.ДобавитьТестовыйНабор("Перепроведение")
			.ДобавитьСерверныйТест("ТестПерепроведение");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// TP-01: Одна партия с НКДПолученный, погашение
Процедура ТестОднаПартияПогашение() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Куп01");
		// Поступление 100 шт, НКД = 20 (НКДПолученный = 20)
		СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 20, 0);

		ДокПогашение = Документы.ПогашениеКупонов.СоздатьДокумент();
		ДокПогашение.Дата = ТекущаяДатаСеанса();
		ДокПогашение.ЦеннаяБумага = ЦеннаяБумага;
		ДокПогашение.НКД = 0.1; // 0.1 * 100 = 10
		ДокПогашение.Записать(РежимЗаписиДокумента.Проведение);

		// Проверка движений СобственныеЦБ
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.ВидДвижения КАК ВидДвижения,
		|	Движения.НКДНакопленный КАК НКДНакопленный,
		|	Движения.НКДПолученный КАК НКДПолученный
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокПогашение.Ссылка);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(1, "одно движение расхода");
		ЮТест.ОжидаетЧто(Таблица[0].ВидДвижения).Равно(ВидДвиженияНакопления.Расход, "расход");
		// НКДНакопленный = 0 (нет накопленного), НКДПолученный = 10
		ЮТест.ОжидаетЧто(Таблица[0].НКДНакопленный).Равно(0, "НКДНакопленный = 0");
		ЮТест.ОжидаетЧто(Таблица[0].НКДПолученный).Равно(10, "НКДПолученный = 10");

		// Проверка ФинансовыйРезультат
		ЗапросФР = Новый Запрос;
		ЗапросФР.Текст =
		"ВЫБРАТЬ
		|	ФинРез.Сумма КАК Сумма
		|ИЗ
		|	РегистрНакопления.ФинансовыйРезультат КАК ФинРез
		|ГДЕ
		|	ФинРез.Регистратор = &Регистратор";
		ЗапросФР.УстановитьПараметр("Регистратор", ДокПогашение.Ссылка);

		ТаблицаФР = ЗапросФР.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(ТаблицаФР.Количество()).Равно(1, "одно движение ФинРез");
		ЮТест.ОжидаетЧто(ТаблицаФР[0].Сумма).Равно(10, "Сумма ФинРез = 10");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// TP-02: Две партии
Процедура ТестДвеПартииПогашение() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Куп02");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 60, 50, 12, 0); // НКДПолученный = 12
		СоздатьИПровестиПоступление(ЦеннаяБумага, 40, 50, 8, 0);  // НКДПолученный = 8

		ДокПогашение = Документы.ПогашениеКупонов.СоздатьДокумент();
		ДокПогашение.Дата = ТекущаяДатаСеанса();
		ДокПогашение.ЦеннаяБумага = ЦеннаяБумага;
		ДокПогашение.НКД = 0.1; // 60*0.1=6, 40*0.1=4 → итого 10
		ДокПогашение.Записать(РежимЗаписиДокумента.Проведение);

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.НКДПолученный КАК НКДПолученный
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокПогашение.Ссылка);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(2, "два движения");
		ЮТест.ОжидаетЧто(Таблица.Итог("НКДПолученный")).Равно(10, "итого НКД списано = 10");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

