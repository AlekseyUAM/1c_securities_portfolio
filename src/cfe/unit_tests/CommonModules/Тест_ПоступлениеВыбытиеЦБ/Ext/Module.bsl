		КонецПопытки;

		// Assert: проведение должно быть отменено
		ЮТест.ОжидаетЧто(ВызваноИсключение).ЭтоИстина("проведение отменено с ошибкой при недостаточном остатке");

		// Assert: сообщение об ошибке содержит имя бумаги (M-POST-03)
		МассивСообщений = ПолучитьСообщенияПользователю(Истина);
		НайденоСообщение = Ложь;
		Для Каждого Сообщение Из МассивСообщений Цикл
			Если СтрНайти(Сообщение.Текст, "ТестTP05") > 0 ИЛИ СтрНайти(Сообщение.Текст, "ТестоваяЦБ") > 0 Тогда
				НайденоСообщение = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		ЮТест.ОжидаетЧто(НайденоСообщение).ЭтоИстина("сообщение об ошибке содержит наименование бумаги");

		// Примечание: запрос к регистрам после неудачного проведения невозможен —
		// платформа помечает транзакцию как ошибочную. Отсутствие движений гарантируется
		// откатом транзакции при Отказ = Истина.

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

