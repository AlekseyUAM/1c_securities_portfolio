// TP-05: Выбытие -- недостаточно остатков (M-POST-03, N-POST-02)
// ============================================================

Процедура ТестTP05ВыбытиеНедостаточноОстатков() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: поступление 50 шт
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестTP05");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 50, 100, 0, 0);

		// Act: пытаемся списать 100 шт (больше, чем есть)
		ДокВыбытие = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокВыбытие.Дата = ТекущаяДатаСеанса();
		ДокВыбытие.ВидОперации = Перечисления.ВидыОперацийЦБ.Выбытие;
		ДокВыбытие.ЦеннаяБумага = ЦеннаяБумага;
		ДокВыбытие.Количество = 100;
		ДокВыбытие.Цена = 110;
		ДокВыбытие.НКД = 0;

		// Перехватываем сообщения пользователю перед проведением
		ПолучитьСообщенияПользователю(Истина);

		ВызваноИсключение = Ложь;
		Попытка
			ДокВыбытие.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
