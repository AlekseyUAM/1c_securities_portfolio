// Покрывает сценарии из Test Plan (SPEC-003), TP-01..TP-08.
// Фаза 4 (Tester): дополнено граничными случаями и регрессией.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
// Все тесты серверные.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("Поступление")
			.ДобавитьСерверныйТест("ТестTP01ПроведениеПоступленияБазовое")
			.ДобавитьСерверныйТест("ТестTP02ПоступлениеНесколькоКомиссий")
			.ДобавитьСерверныйТест("ТестTP07ПоступлениеНеСоздаетФинРез")
		.ДобавитьТестовыйНабор("ВыбытиеОднаПартия")
			.ДобавитьСерверныйТест("ТестTP03ВыбытиеОднаПартияПолноеСписание")
		.ДобавитьТестовыйНабор("ВыбытиеFIFO")
			.ДобавитьСерверныйТест("ТестTP04ВыбытиеFIFOНесколькоПартий")
		.ДобавитьТестовыйНабор("ВыбытиеОшибки")
			.ДобавитьСерверныйТест("ТестTP05ВыбытиеНедостаточноОстатков")
			.ДобавитьСерверныйТест("ТестTP06ВыбытиеНетПартий")
		.ДобавитьТестовыйНабор("КорректностьДвижений")
			.ДобавитьСерверныйТест("ТестTP08ВыбытиеНеСоздаетПриход")
		.ДобавитьТестовыйНабор("ГраничныеСлучаи")
			.ДобавитьСерверныйТест("ТестПоступлениеБезКомиссийИНКД")
			.ДобавитьСерверныйТест("ТестОперацияСОднойЕдиницей")
			.ДобавитьСерверныйТест("ТестПерепроведениеДокументаПоступления")
			.ДобавитьСерверныйТест("ТестВыбытиеТочноВОднуПартию")
			.ДобавитьСерверныйТест("ТестВыбытиеПолноеПотреблениеВсехПартий")
			.ДобавитьСерверныйТест("ТестПерепроведениеДокументаВыбытия")
		.ДобавитьТестовыйНабор("ПорядокФИФО")
			.ДобавитьСерверныйТест("ТестФИФОРанняяПартияСписываетсяПервой")
		.ДобавитьТестовыйНабор("Регрессия")
			.ДобавитьСерверныйТест("ТестРегрессияКотировкиЦБНеЗатронуты")
			.ДобавитьСерверныйТест("ТестИнтеграцияПоследовательныеОперации");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// ============================================================
// TP-01: Проведение Поступления -- базовое (M-POST-01, M-REG-03)
// ============================================================

Процедура ТестTP01ПроведениеПоступленияБазовое() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестTP01");

		ДокументОбъект = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокументОбъект.Дата = ТекущаяДатаСеанса();
		ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
		ДокументОбъект.ЦеннаяБумага = ЦеннаяБумага;
		ДокументОбъект.Количество = 100;
		ДокументОбъект.Цена = 50;
		ДокументОбъект.НКД = 10;

		НоваяСтрока = ДокументОбъект.Комиссии.Добавить();
		НоваяСтрока.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		НоваяСтрока.Сумма = 25;

		// Act
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

		// Assert: проверяем движения по СобственныеЦБ
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.ВидДвижения КАК ВидДвижения,
		|	Движения.ЦеннаяБумага КАК ЦеннаяБумага,
		|	Движения.Партия КАК Партия,
		|	Движения.Количество КАК Количество,
		|	Движения.Стоимость КАК Стоимость,
		|	Движения.НКДПолученный КАК НКДПолученный,
		|	Движения.Затраты КАК Затраты,
		|	Движения.Переоценка КАК Переоценка,
		|	Движения.НКДНакопленный КАК НКДНакопленный
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокументОбъект.Ссылка);

		РезультатЗапроса = Запрос.Выполнить();
		ЮТест.ОжидаетЧто(РезультатЗапроса.Пустой()).ЭтоЛожь("движения по СобственныеЦБ существуют");

		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();

		ЮТест.ОжидаетЧто(Выборка.ВидДвижения).Равно(ВидДвиженияНакопления.Приход, "вид движения = Приход");
		ЮТест.ОжидаетЧто(Выборка.Партия).Равно(ДокументОбъект.Ссылка, "партия = ссылка на документ");
		ЮТест.ОжидаетЧто(Выборка.Количество).Равно(100, "количество = 100");
		ЮТест.ОжидаетЧто(Выборка.Стоимость).Равно(5000, "стоимость = 5000");
		ЮТест.ОжидаетЧто(Выборка.НКДПолученный).Равно(10, "НКД полученный = 10");
		ЮТест.ОжидаетЧто(Выборка.Затраты).Равно(25, "затраты = 25");
		ЮТест.ОжидаетЧто(Выборка.Переоценка).Равно(0, "переоценка = 0");
		ЮТест.ОжидаетЧто(Выборка.НКДНакопленный).Равно(0, "НКД накопленный = 0");

		// Assert: нет движений по ФинансовыйРезультат (дублирует TP-07 для полноты)
		ЗапросФинРез = Новый Запрос;
		ЗапросФинРез.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(*) КАК Количество
		|ИЗ
		|	РегистрНакопления.ФинансовыйРезультат КАК ФинРез
		|ГДЕ
		|	ФинРез.Регистратор = &Регистратор";
		ЗапросФинРез.УстановитьПараметр("Регистратор", ДокументОбъект.Ссылка);

		ВыборкаФР = ЗапросФинРез.Выполнить().Выбрать();
		ВыборкаФР.Следующий();
		ЮТест.ОжидаетЧто(ВыборкаФР.Количество).Равно(0, "нет движений по ФинансовыйРезультат");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// ============================================================
// TP-02: Поступление -- несколько комиссий (M-POST-01)
// ============================================================

Процедура ТестTP02ПоступлениеНесколькоКомиссий() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестTP02");

		ДокументОбъект = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокументОбъект.Дата = ТекущаяДатаСеанса();
		ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
		ДокументОбъект.ЦеннаяБумага = ЦеннаяБумага;
		ДокументОбъект.Количество = 50;
		ДокументОбъект.Цена = 100;
		ДокументОбъект.НКД = 0;

		Строка1 = ДокументОбъект.Комиссии.Добавить();
		Строка1.ВидКомиссии = Перечисления.ВидыКомиссий.БиржеваяКомиссия;
		Строка1.Сумма = 10;

		Строка2 = ДокументОбъект.Комиссии.Добавить();
		Строка2.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		Строка2.Сумма = 15;

		// Act
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

		// Assert
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.Стоимость КАК Стоимость,
		|	Движения.Затраты КАК Затраты
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокументОбъект.Ссылка);

		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();

		ЮТест.ОжидаетЧто(Выборка.Стоимость).Равно(5000, "стоимость = 50 * 100 = 5000");
		ЮТест.ОжидаетЧто(Выборка.Затраты).Равно(25, "затраты = 10 + 15 = 25");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// ============================================================
// TP-03: Выбытие -- одна партия, полное списание (M-POST-02, M-POST-04, M-REG-04)
// ============================================================

Процедура ТестTP03ВыбытиеОднаПартияПолноеСписание() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: сначала поступление
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестTP03");

		ДокПоступление = СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 10, 25);

		// Act: выбытие
		ДокВыбытие = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокВыбытие.Дата = ТекущаяДатаСеанса();
		ДокВыбытие.ВидОперации = Перечисления.ВидыОперацийЦБ.Выбытие;
		ДокВыбытие.ЦеннаяБумага = ЦеннаяБумага;
		ДокВыбытие.Количество = 100;
		ДокВыбытие.Цена = 55;
		ДокВыбытие.НКД = 5;

		СтрокаКомиссии = ДокВыбытие.Комиссии.Добавить();
		СтрокаКомиссии.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		СтрокаКомиссии.Сумма = 20;

		ДокВыбытие.Записать(РежимЗаписиДокумента.Проведение);

		// Assert: движения по СобственныеЦБ (расход)
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.ВидДвижения КАК ВидДвижения,
		|	Движения.Количество КАК Количество,
		|	Движения.Стоимость КАК Стоимость,
		|	Движения.Переоценка КАК Переоценка,
		|	Движения.НКДПолученный КАК НКДПолученный,
		|	Движения.НКДНакопленный КАК НКДНакопленный,
		|	Движения.Затраты КАК Затраты
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокВыбытие.Ссылка);

		РезультатЗапроса = Запрос.Выполнить();
		ЮТест.ОжидаетЧто(РезультатЗапроса.Пустой()).ЭтоЛожь("движения расхода существуют");

		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();

		ЮТест.ОжидаетЧто(Выборка.ВидДвижения).Равно(ВидДвиженияНакопления.Расход, "вид движения = Расход");
		ЮТест.ОжидаетЧто(Выборка.Количество).Равно(100, "списано количество = 100");
		ЮТест.ОжидаетЧто(Выборка.Стоимость).Равно(5000, "списана стоимость = 5000");
		ЮТест.ОжидаетЧто(Выборка.Переоценка).Равно(0, "списана переоценка = 0");
		ЮТест.ОжидаетЧто(Выборка.НКДПолученный).Равно(10, "списан НКД полученный = 10");
		ЮТест.ОжидаетЧто(Выборка.НКДНакопленный).Равно(0, "списан НКД накопленный = 0");
		ЮТест.ОжидаетЧто(Выборка.Затраты).Равно(25, "списаны затраты = 25");

		// Assert: ФинансовыйРезультат
		// Выручка = 55 * 100 + 5 - 20 = 5485
		// Списано = 5000 + 0 + 10 + 0 + 25 = 5035
		// Сумма = 5485 - 5035 = 450
		ЗапросФинРез = Новый Запрос;
		ЗапросФинРез.Текст =
		"ВЫБРАТЬ
		|	ФинРез.Сумма КАК Сумма
		|ИЗ
		|	РегистрНакопления.ФинансовыйРезультат КАК ФинРез
		|ГДЕ
		|	ФинРез.Регистратор = &Регистратор";
		ЗапросФинРез.УстановитьПараметр("Регистратор", ДокВыбытие.Ссылка);

		ВыборкаФР = ЗапросФинРез.Выполнить().Выбрать();
		ЮТест.ОжидаетЧто(ВыборкаФР.Следующий()).ЭтоИстина("есть запись ФинансовыйРезультат");
		ЮТест.ОжидаетЧто(ВыборкаФР.Сумма).Равно(450, "финансовый результат = 450");

		// Assert: остаток по СобственныеЦБ = 0
		ЗапросОстатки = Новый Запрос;
		ЗапросОстатки.Текст =
		"ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(Остатки.КоличествоОстаток), 0) КАК КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ.Остатки(, ЦеннаяБумага = &ЦеннаяБумага) КАК Остатки";
		ЗапросОстатки.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

		ВыборкаОстатки = ЗапросОстатки.Выполнить().Выбрать();
		ВыборкаОстатки.Следующий();
		ЮТест.ОжидаетЧто(ВыборкаОстатки.КоличествоОстаток).Равно(0, "остаток по бумаге = 0 (все списано)");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// ============================================================
// TP-04: Выбытие FIFO через несколько партий (M-POST-02, M-POST-05)
// ============================================================

Процедура ТестTP04ВыбытиеFIFOНесколькоПартий() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестTP04");

		// Поступление 1: 60 шт по 40, комиссия 12
		ДокПост1 = СоздатьИПровестиПоступление(ЦеннаяБумага, 60, 40, 0, 12);

		// Поступление 2: 80 шт по 50, комиссия 16
		ДокПост2 = СоздатьИПровестиПоступление(ЦеннаяБумага, 80, 50, 0, 16);

		// Act: Выбытие 100 шт
		ДокВыбытие = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокВыбытие.Дата = ТекущаяДатаСеанса();
		ДокВыбытие.ВидОперации = Перечисления.ВидыОперацийЦБ.Выбытие;
		ДокВыбытие.ЦеннаяБумага = ЦеннаяБумага;
		ДокВыбытие.Количество = 100;
		ДокВыбытие.Цена = 55;
		ДокВыбытие.НКД = 0;

		СтрокаКомиссии = ДокВыбытие.Комиссии.Добавить();
		СтрокаКомиссии.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		СтрокаКомиссии.Сумма = 20;

		ДокВыбытие.Записать(РежимЗаписиДокумента.Проведение);

		// Assert: два движения расхода по СобственныеЦБ
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.Партия КАК Партия,
		|	Движения.Количество КАК Количество,
		|	Движения.Стоимость КАК Стоимость,
		|	Движения.Затраты КАК Затраты
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|УПОРЯДОЧИТЬ ПО
		|	Движения.Партия.Дата ВОЗР";
		Запрос.УстановитьПараметр("Регистратор", ДокВыбытие.Ссылка);

		РезультатЗапроса = Запрос.Выполнить();
		ТаблицаДвижений = РезультатЗапроса.Выгрузить();

		ЮТест.ОжидаетЧто(ТаблицаДвижений.Количество()).Равно(2, "два движения расхода (FIFO по двум партиям)");

		// Партия 1: полное списание 60 шт
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Количество).Равно(60, "партия 1: количество = 60");
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Стоимость).Равно(2400, "партия 1: стоимость = 2400");
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Затраты).Равно(12, "партия 1: затраты = 12");

		// Партия 2: частичное списание 40 из 80 (доля = 0.5)
		ЮТест.ОжидаетЧто(ТаблицаДвижений[1].Количество).Равно(40, "партия 2: количество = 40");
		ЮТест.ОжидаетЧто(ТаблицаДвижений[1].Стоимость).Равно(2000, "партия 2: стоимость = 4000 * 0.5 = 2000");
		ЮТест.ОжидаетЧто(ТаблицаДвижений[1].Затраты).Равно(8, "партия 2: затраты = 16 * 0.5 = 8");

		// Assert: ФинансовыйРезультат
		// Выручка = 55 * 100 + 0 - 20 = 5480
		// Списано = (2400 + 0 + 0 + 0 + 12) + (2000 + 0 + 0 + 0 + 8) = 4420
		// Сумма = 5480 - 4420 = 1060
		ЗапросФинРез = Новый Запрос;
		ЗапросФинРез.Текст =
		"ВЫБРАТЬ
		|	ФинРез.Сумма КАК Сумма
		|ИЗ
		|	РегистрНакопления.ФинансовыйРезультат КАК ФинРез
		|ГДЕ
		|	ФинРез.Регистратор = &Регистратор";
		ЗапросФинРез.УстановитьПараметр("Регистратор", ДокВыбытие.Ссылка);

		ВыборкаФР = ЗапросФинРез.Выполнить().Выбрать();
