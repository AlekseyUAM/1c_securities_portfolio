// Regression: проверяем, что операции с документом ПоступлениеВыбытиеЦБ
// не затрагивают существующий регистр сведений КотировкиЦБ
Процедура ТестРегрессияКотировкиЦБНеЗатронуты() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: создаем котировку
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестРег01");

		НаборЗаписей = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ЦеннаяБумага.Установить(ЦеннаяБумага);
		НаборЗаписей.Отбор.ВидКотировки.Установить(Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия);
		НаборЗаписей.Отбор.Период.Установить(ТекущаяДатаСеанса());

		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ТекущаяДатаСеанса();
		НоваяЗапись.ЦеннаяБумага = ЦеннаяБумага;
		НоваяЗапись.ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;
		НоваяЗапись.Значение = 42.5;
		НаборЗаписей.Записать();

		// Act: проводим поступление
		СоздатьИПровестиПоступление(ЦеннаяБумага, 10, 100, 0, 0);

		// Assert: котировка не изменилась
		Котировка = РегистрыСведений.КотировкиЦБ.ПолучитьПоследнее(
			ТекущаяДатаСеанса(),
			Новый Структура("ЦеннаяБумага, ВидКотировки",
				ЦеннаяБумага,
				Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия));

		ЮТест.ОжидаетЧто(Котировка.Значение).Равно(42.5, "котировка не изменилась после проведения документа");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// Integration: последовательные операции поступления и выбытия
// с проверкой промежуточных остатков
Процедура ТестИнтеграцияПоследовательныеОперации() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестИнтег01");

		// Поступление 1: 100 шт по 50, комиссия 10
		СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 0, 10);

		// Выбытие 1: 30 шт по 60
		ДокВыб1 = СоздатьИПровестиВыбытие(ЦеннаяБумага, 30, 60, 0, 0);

		// Проверяем остаток после первого выбытия: 70 шт
		ПроверитьОстатокЦБ(ЦеннаяБумага, 70, "после первого выбытия");

		// Поступление 2: 50 шт по 80, комиссия 5
		СоздатьИПровестиПоступление(ЦеннаяБумага, 50, 80, 0, 5);

		// Проверяем остаток: 70 + 50 = 120 шт
		ПроверитьОстатокЦБ(ЦеннаяБумага, 120, "после второго поступления");

		// Выбытие 2: 90 шт по 90 (списывает остаток партии 1 = 70 + частично партию 2 = 20)
		ДокВыб2 = СоздатьИПровестиВыбытие(ЦеннаяБумага, 90, 90, 0, 0);

		// Проверяем остаток: 120 - 90 = 30 шт
		ПроверитьОстатокЦБ(ЦеннаяБумага, 30, "после второго выбытия");

		// Проверяем что второе выбытие создало 2 движения (FIFO: остаток партии 1 + часть партии 2)
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(*) КАК КолДвижений
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокВыб2);

		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		ЮТест.ОжидаетЧто(Выборка.КолДвижений).Равно(2, "второе выбытие: 2 движения расхода (FIFO)");

		// Выбытие 3: оставшиеся 30 шт
		СоздатьИПровестиВыбытие(ЦеннаяБумага, 30, 100, 0, 0);

		// Проверяем итоговый остаток: 0
		ПроверитьОстатокЦБ(ЦеннаяБумага, 0, "после полного списания");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// ============================================================
// Порядок ФИФО: ранняя партия списывается первой
// ============================================================

// Тест создаёт две партии с РАЗНЫМИ датами и проверяет, что при выбытии
// первой списывается именно более ранняя партия (с меньшей датой),
// а не более поздняя (с большей ценой/стоимостью).
Процедура ТестФИФОРанняяПартияСписываетсяПервой() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: две партии с ЯВНО разными датами
		ЦеннаяБумага = СоздатьТестовуюЦБ("ТестФИФО_Порядок");

		// Партия 1 (ранняя): 50 шт по 100, дата = вчера
		ДокПост1 = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокПост1.Дата = НачалоДня(ТекущаяДатаСеанса()) - 86400; // вчера
		ДокПост1.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
		ДокПост1.ЦеннаяБумага = ЦеннаяБумага;
		ДокПост1.Количество = 50;
		ДокПост1.Цена = 100;
		ДокПост1.НКД = 0;
		ДокПост1.Записать(РежимЗаписиДокумента.Проведение);

		// Партия 2 (поздняя): 50 шт по 200, дата = сегодня
		ДокПост2 = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокПост2.Дата = ТекущаяДатаСеанса();
		ДокПост2.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
		ДокПост2.ЦеннаяБумага = ЦеннаяБумага;
		ДокПост2.Количество = 50;
		ДокПост2.Цена = 200;
		ДокПост2.НКД = 0;
		ДокПост2.Записать(РежимЗаписиДокумента.Проведение);

		// Act: выбытие 30 шт — должна списаться РАННЯЯ партия (по 100), а не поздняя (по 200)
		ДокВыбытие = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
		ДокВыбытие.Дата = ТекущаяДатаСеанса();
		ДокВыбытие.ВидОперации = Перечисления.ВидыОперацийЦБ.Выбытие;
		ДокВыбытие.ЦеннаяБумага = ЦеннаяБумага;
		ДокВыбытие.Количество = 30;
		ДокВыбытие.Цена = 150;
		ДокВыбытие.НКД = 0;
		ДокВыбытие.Записать(РежимЗаписиДокумента.Проведение);

		// Assert: одно движение расхода, и оно из РАННЕЙ партии (стоимость 100 * 30 = 3000, не 200 * 30 = 6000)
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.Партия КАК Партия,
		|	Движения.Количество КАК Количество,
		|	Движения.Стоимость КАК Стоимость
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|УПОРЯДОЧИТЬ ПО
		|	Движения.Партия.Дата";
		Запрос.УстановитьПараметр("Регистратор", ДокВыбытие.Ссылка);

		ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(ТаблицаДвижений.Количество()).Равно(1, "одно движение расхода");

		// Ключевая проверка: списана именно ранняя партия
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Партия).Равно(ДокПост1.Ссылка,
			"ФИФО: списана ранняя партия (вчера), а не поздняя (сегодня)");
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Количество).Равно(30, "количество = 30");
		// Стоимость из ранней партии: доля = 30/50 = 0.6, стоимость = 5000 * 0.6 = 3000
		ЮТест.ОжидаетЧто(ТаблицаДвижений[0].Стоимость).Равно(3000,
			"стоимость = 3000 (из ранней партии по 100), а не 6000 (из поздней по 200)");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создает тестовый элемент справочника ЦенныеБумаги.
//
// Параметры:
//   Префикс - Строка - префикс для уникального наименования.
//
// Возвращаемое значение:
//   СправочникСсылка.ЦенныеБумаги - ссылка на созданный элемент.
//
Функция СоздатьТестовуюЦБ(Префикс)

	НовыйЭлемент = Справочники.ЦенныеБумаги.СоздатьЭлемент();
	НовыйЭлемент.Наименование = Префикс + "_ТестоваяЦБ_" + Строка(Новый УникальныйИдентификатор);
	НовыйЭлемент.Тикер = Лев(Префикс, 10);
	НовыйЭлемент.Записать();

	Возврат НовыйЭлемент.Ссылка;

КонецФункции

// Создает и проводит документ поступления ЦБ.
//
// Параметры:
//   ЦеннаяБумага - СправочникСсылка.ЦенныеБумаги
//   Количество   - Число
//   Цена         - Число
//   НКД          - Число
//   СуммаКомиссии - Число - общая сумма комиссии (одна строка БрокерскаяКомиссия)
//
// Возвращаемое значение:
//   ДокументСсылка.ПоступлениеВыбытиеЦБ - ссылка на проведенный документ.
//
Функция СоздатьИПровестиПоступление(ЦеннаяБумага, Количество, Цена, НКД, СуммаКомиссии)

	ДокументОбъект = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
	ДокументОбъект.Дата = ТекущаяДатаСеанса();
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
	ДокументОбъект.ЦеннаяБумага = ЦеннаяБумага;
	ДокументОбъект.Количество = Количество;
	ДокументОбъект.Цена = Цена;
	ДокументОбъект.НКД = НКД;

	Если СуммаКомиссии > 0 Тогда
		СтрокаКомиссии = ДокументОбъект.Комиссии.Добавить();
		СтрокаКомиссии.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		СтрокаКомиссии.Сумма = СуммаКомиссии;
	КонецЕсли;

	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

	Возврат ДокументОбъект.Ссылка;

КонецФункции

// Создает и проводит документ выбытия ЦБ.
//
// Параметры:
//   ЦеннаяБумага  - СправочникСсылка.ЦенныеБумаги
//   Количество    - Число
//   Цена          - Число
//   НКД           - Число
//   СуммаКомиссии - Число
//
// Возвращаемое значение:
//   ДокументСсылка.ПоступлениеВыбытиеЦБ
//
Функция СоздатьИПровестиВыбытие(ЦеннаяБумага, Количество, Цена, НКД, СуммаКомиссии)

	ДокументОбъект = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
	ДокументОбъект.Дата = ТекущаяДатаСеанса();
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЦБ.Выбытие;
	ДокументОбъект.ЦеннаяБумага = ЦеннаяБумага;
	ДокументОбъект.Количество = Количество;
	ДокументОбъект.Цена = Цена;
	ДокументОбъект.НКД = НКД;

	Если СуммаКомиссии > 0 Тогда
		СтрокаКомиссии = ДокументОбъект.Комиссии.Добавить();
		СтрокаКомиссии.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		СтрокаКомиссии.Сумма = СуммаКомиссии;
	КонецЕсли;

	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

	Возврат ДокументОбъект.Ссылка;

КонецФункции

// Проверяет текущий остаток количества ЦБ в регистре СобственныеЦБ.
//
// Параметры:
//   ЦеннаяБумага    - СправочникСсылка.ЦенныеБумаги
//   ОжидаемыйОстаток - Число
//   Контекст        - Строка - описание проверки для сообщения об ошибке
//
Процедура ПроверитьОстатокЦБ(ЦеннаяБумага, ОжидаемыйОстаток, Контекст)

	ЗапросОст = Новый Запрос;
	ЗапросОст.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Остатки.КоличествоОстаток), 0) КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.СобственныеЦБ.Остатки(, ЦеннаяБумага = &ЦеннаяБумага) КАК Остатки";
	ЗапросОст.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

	ВыборкаОст = ЗапросОст.Выполнить().Выбрать();
	ВыборкаОст.Следующий();
	ЮТест.ОжидаетЧто(ВыборкаОст.КоличествоОстаток).Равно(ОжидаемыйОстаток, "остаток " + Контекст);

КонецПроцедуры

#КонецОбласти
