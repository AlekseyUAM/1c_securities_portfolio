// Тест-модуль YaxUnit: Тест_КотировкаЦБ_Данные
// Покрывает сценарии T-03..T-07 из Test Plan (SPEC-007).
// T-03: Строки отфильтрованы по ЦеннаяБумага (R-03, AC-02).
// T-04: Строки отфильтрованы по периоду (R-03, AC-02).
// T-05: Отсортированы по дате (R-04, AC-02).
// T-06: Обязательный параметр ЦеннаяБумага (R-02).
// T-07: Пустые остатки — нет котировок в период (SHOULD T-05 в spec).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("КотировкаЦБ_Данные")
			.ДобавитьСерверныйТест("ТестТ03ФильтрПоЦеннойБумаге")
			.ДобавитьСерверныйТест("ТестТ04ФильтрПоПериоду")
			.ДобавитьСерверныйТест("ТестТ05СортировкаПоДате")
			.ДобавитьСерверныйТест("ТестТ06ФильтрБезЦеннойБумаги")
			.ДобавитьСерверныйТест("ТестТ07ПустойРезультат");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-03: Строки отфильтрованы по ЦеннаяБумага.
// Связь: R-02, R-03, AC-02.
// При указании ЦеннаяБумага=X отчет не должен содержать записи для ЦеннаяБумага=Y.
//
Процедура ТестТ03ФильтрПоЦеннойБумаге() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: создаем две ценные бумаги и по одной котировке для каждой
		ЦБ_X = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ЦБ_Y = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");

		ДатаКотировки = '20260101';
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;

		// Запись котировки для ЦБ_X
		НаборЗаписей = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ЦеннаяБумага.Установить(ЦБ_X);
		НаборЗаписей.Отбор.ВидКотировки.Установить(ВидКотировки);
		НаборЗаписей.Отбор.Период.Установить(ДатаКотировки);
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ДатаКотировки;
		НоваяЗапись.ЦеннаяБумага = ЦБ_X;
		НоваяЗапись.ВидКотировки = ВидКотировки;
		НоваяЗапись.Значение = 100;
		НаборЗаписей.Записать();

		// Запись котировки для ЦБ_Y
		НаборЗаписей2 = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
		НаборЗаписей2.Отбор.ЦеннаяБумага.Установить(ЦБ_Y);
		НаборЗаписей2.Отбор.ВидКотировки.Установить(ВидКотировки);
		НаборЗаписей2.Отбор.Период.Установить(ДатаКотировки);
		НоваяЗапись2 = НаборЗаписей2.Добавить();
		НоваяЗапись2.Период = ДатаКотировки;
		НоваяЗапись2.ЦеннаяБумага = ЦБ_Y;
		НоваяЗапись2.ВидКотировки = ВидКотировки;
		НоваяЗапись2.Значение = 200;
		НаборЗаписей2.Записать();

		// Act: формируем отчет только по ЦБ_X
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ЦеннаяБумага", ЦБ_X);
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетКотировкаЦБ(ПараметрыОтчета);

		// Assert: в результате есть строки для ЦБ_X
		ЮТест.ОжидаетЧто(РезультатОтчета.Количество())
			.Больше(0, "Отчет должен содержать строки для ЦБ_X");

		// Assert: в результате НЕТ строк для ЦБ_Y
		НайденыСтрокиДляЦБ_Y = Ложь;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ_Y Тогда
				НайденыСтрокиДляЦБ_Y = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(НайденыСтрокиДляЦБ_Y)
			.ЭтоЛожь("Отчет не должен содержать строки для ЦБ_Y при фильтре по ЦБ_X");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-04: Строки отфильтрованы по периоду.
// Связь: R-03, AC-02.
// Запись вне диапазона дат должна отсутствовать в результате.
//
Процедура ТестТ04ФильтрПоПериоду() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: ценная бумага с котировками внутри и вне периода
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;

		// Котировка внутри периода (15 января)
		ДатаВнутри = '20260115';
		НаборВнутри = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
		НаборВнутри.Отбор.ЦеннаяБумага.Установить(ЦБ);
		НаборВнутри.Отбор.ВидКотировки.Установить(ВидКотировки);
		НаборВнутри.Отбор.Период.Установить(ДатаВнутри);
		ЗаписьВнутри = НаборВнутри.Добавить();
		ЗаписьВнутри.Период = ДатаВнутри;
		ЗаписьВнутри.ЦеннаяБумага = ЦБ;
		ЗаписьВнутри.ВидКотировки = ВидКотировки;
		ЗаписьВнутри.Значение = 150;
		НаборВнутри.Записать();

		// Котировка вне периода (1 марта — после КонецПериода)
		ДатаВне = '20260301';
		НаборВне = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
		НаборВне.Отбор.ЦеннаяБумага.Установить(ЦБ);
		НаборВне.Отбор.ВидКотировки.Установить(ВидКотировки);
		НаборВне.Отбор.Период.Установить(ДатаВне);
		ЗаписьВне = НаборВне.Добавить();
		ЗаписьВне.Период = ДатаВне;
		ЗаписьВне.ЦеннаяБумага = ЦБ;
		ЗаписьВне.ВидКотировки = ВидКотировки;
		ЗаписьВне.Значение = 999;
		НаборВне.Записать();

		// Act: формируем отчет за январь 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ЦеннаяБумага", ЦБ);
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетКотировкаЦБ(ПараметрыОтчета);

		// Assert: котировка 15 января должна быть в результате
		НайдениВнутри = Ложь;
		НайденоВне = Ложь;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.Период = ДатаВнутри Тогда
				НайдениВнутри = Истина;
			КонецЕсли;
			Если Строка.Период = ДатаВне Тогда
				НайденоВне = Истина;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(НайдениВнутри)
			.ЭтоИстина("Котировка в периоде должна быть в результате");
		ЮТест.ОжидаетЧто(НайденоВне)
			.ЭтоЛожь("Котировка вне периода НЕ должна быть в результате");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-05: Строки в результате упорядочены по Период по возрастанию.
// Связь: R-04, AC-02.
//
Процедура ТестТ05СортировкаПоДате() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: три котировки в разном порядке
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;

		МассивДат = Новый Массив;
		МассивДат.Добавить('20260120');
		МассивДат.Добавить('20260105');
		МассивДат.Добавить('20260115');

		Для Каждого ДатаКот Из МассивДат Цикл
			НаборЗаписей = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ЦеннаяБумага.Установить(ЦБ);
			НаборЗаписей.Отбор.ВидКотировки.Установить(ВидКотировки);
			НаборЗаписей.Отбор.Период.Установить(ДатаКот);
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Период = ДатаКот;
			НоваяЗапись.ЦеннаяБумага = ЦБ;
			НоваяЗапись.ВидКотировки = ВидКотировки;
			НоваяЗапись.Значение = 100;
			НаборЗаписей.Записать();
		КонецЦикла;

		// Act: формируем отчет
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ЦеннаяБумага", ЦБ);
		ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
		ПараметрыОтчета.Вставить("КонецПериода", '20260131');

		РезультатОтчета = СформироватьОтчетКотировкаЦБ(ПараметрыОтчета);

		// Assert: минимум три строки
		ЮТест.ОжидаетЧто(РезультатОтчета.Количество())
			.БольшеИлиРавно(3, "Должны быть все три котировки");

		// Assert: проверяем порядок — каждая следующая дата >= предыдущей
		ПредыдущаяДата = '00010101';
		Для Каждого Строка Из РезультатОтчета Цикл
			ЮТест.ОжидаетЧто(Строка.Период)
				.БольшеИлиРавно(ПредыдущаяДата, "Строки должны быть отсортированы по Период по возрастанию");
			ПредыдущаяДата = Строка.Период;
		КонецЦикла;

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-06: Обязательный параметр ЦеннаяБумага.
// Связь: R-02.
// При пустом параметре ЦеннаяБумага отчет формируется без ошибок (пустой или штатный результат).
// Согласно тех. дизайну: параметр ЦеннаяБумага задан в запросе как условие WHERE,
// при пустом значении отчет возвращает пустой набор (не исключение).
//
Процедура ТестТ06ФильтрБезЦеннойБумаги() Экспорт

	// Arrange: параметр ЦеннаяБумага не задан (пустая ссылка)
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("ЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	ПараметрыОтчета.Вставить("НачалоПериода", '20260101');
	ПараметрыОтчета.Вставить("КонецПериода", '20260131');

	// Act: отчет должен сформироваться без исключения
	ВызваноИсключение = Ложь;
	РезультатОтчета = Неопределено;
	Попытка
		РезультатОтчета = СформироватьОтчетКотировкаЦБ(ПараметрыОтчета);
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	// Assert: формирование отчета без ЦеннаяБумага не должно вызывать исключение
	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Формирование отчета с пустой ЦеннаяБумага не должно вызывать исключение");

	// Assert: результат получен
	ЮТест.ОжидаетЧто(РезультатОтчета)
		.НеРавно(Неопределено, "Результат отчета должен быть получен");

КонецПроцедуры

// T-07: Пустые остатки — нет котировок в период.
// Связь: SHOULD T-05 в spec (пустой результат при отсутствии котировок за период).
// При отсутствии котировок за период отчет формируется без ошибок, результат пустой.
//
Процедура ТестТ07ПустойРезультат() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: ценная бумага без котировок
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");

		// Act: формируем отчет за период без котировок
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ЦеннаяБумага", ЦБ);
		ПараметрыОтчета.Вставить("НачалоПериода", '20250101');
		ПараметрыОтчета.Вставить("КонецПериода", '20250131');

		ВызваноИсключение = Ложь;
		РезультатОтчета = Неопределено;
		Попытка
			РезультатОтчета = СформироватьОтчетКотировкаЦБ(ПараметрыОтчета);
		Исключение
			ВызваноИсключение = Истина;
		КонецПопытки;

		// Assert: формирование без ошибок
		ЮТест.ОжидаетЧто(ВызваноИсключение)
			.ЭтоЛожь("Отчет при отсутствии котировок должен формироваться без исключений");

		// Assert: результат пустой (строк нет)
		ЮТест.ОжидаетЧто(РезультатОтчета.Количество())
			.Равно(0, "При отсутствии котировок результат должен быть пустым");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует отчет КотировкаЦБ через СКД и возвращает результат в виде таблицы значений.
//
// Параметры:
//   ПараметрыОтчета - Структура - ключи: ЦеннаяБумага, НачалоПериода, КонецПериода.
//
// Возвращаемое значение:
//   ТаблицаЗначений - строки результата компоновки.
//
Функция СформироватьОтчетКотировкаЦБ(ПараметрыОтчета)

	ОтчетОбъект = Отчеты.КотировкаЦБ.Создать();

	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(
			ОтчетОбъект.СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(
		ОтчетОбъект.СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

	// Установка параметров
	Для Каждого КлючЗначение Из ПараметрыОтчета Цикл
		КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(
			КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(
		ОтчетОбъект.СхемаКомпоновкиДанных,
		КомпоновщикНастроек.Настройки,,,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	КоллекцияЗначений = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(КоллекцияЗначений);
	// Ложь — не создавать вложенную транзакцию внутри СКД-процессора,
	// чтобы запрос выполнялся в контексте текущей внешней транзакции
	// и видел данные, записанные в ней через НаборЗаписей.Записать().
	ПроцессорВывода.Вывести(ПроцессорКомпоновки, Ложь);

	Возврат КоллекцияЗначений;

КонецФункции

#КонецОбласти
