// Тест-модуль YaxUnit: ЮТ_ЦенныеБумагиСервер
// Покрывает MUST-сценарии TC-001 - TC-009 из Test Plan (SPEC-001).

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
// Все тесты серверные (Server=true, без контекста формы).
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("ЗагрузкаИзMOEX")
			.ДобавитьСерверныйТест("ТС001_УспешнаяЗагрузкаПоТикеру")
			.ДобавитьСерверныйТест("ТС002_УспешнаяЗагрузкаПоКоду")
			.ДобавитьСерверныйТест("ТС003_БумагаНеНайдена")
		.ДобавитьТестовыйНабор("РучноеЗаполнение")
			.ДобавитьСерверныйТест("ТС006_РучноеЗаполнениеБезИнтерфейсаПрограммирования")
		.ДобавитьТестовыйНабор("УникальностьМеждународногоКода")
			.ДобавитьСерверныйТест("ТС009_ДублирующийМеждународныйКодВызываетОтказ");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// TC-001: Успешная загрузка карточки по тикеру.
//
Процедура ТС001_УспешнаяЗагрузкаПоТикеру() Экспорт

	// Arrange
	ТикерЗапроса = "SBER";
	КодМеждународный = "";

	// Act
	Результат = ЦенныеБумагиСервер.ЗагрузитьИзMOEX(ТикерЗапроса, КодМеждународный);

	// Assert
	ЮТест.ОжидаетЧто(Результат).НеРавно(Неопределено, "TC-001: результат не Неопределено");

	ЮТест.ОжидаетЧто(Результат.Успех).ЭтоИстина("TC-001: Результат.Успех должен быть Истина");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги).НеРавно(Неопределено, "TC-001: ДанныеБумаги не Неопределено");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги.Наименование).Заполнено("TC-001: Наименование заполнено");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги.ISIN).Заполнено("TC-001: ISIN заполнен");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги.ТипБумаги).Заполнено("TC-001: ТипБумаги заполнен");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги.Тикер).Равно(ТикерЗапроса, "TC-001: Тикер совпадает");

КонецПроцедуры

// TC-002: Успешная загрузка по ISIN при пустом тикере.
//
Процедура ТС002_УспешнаяЗагрузкаПоКоду() Экспорт

	// Arrange
	ПустойТикер = "";
	КодМеждународный = "RU0009029540";

	// Act
	Результат = ЦенныеБумагиСервер.ЗагрузитьИзMOEX(ПустойТикер, КодМеждународный);

	// Assert
	ЮТест.ОжидаетЧто(Результат.Успех).ЭтоИстина("TC-002: загрузка по ISIN успешна");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги).НеРавно(Неопределено, "TC-002: ДанныеБумаги не Неопределено");

	ЮТест.ОжидаетЧто(Результат.ДанныеБумаги.Наименование).Заполнено("TC-002: Наименование заполнено");

КонецПроцедуры

// TC-003: Бумага не найдена в MOEX.
//
Процедура ТС003_БумагаНеНайдена() Экспорт

	// Arrange
	НесуществующийТикер = "НЕИЗВЕСТНЫЙ_ТИКЕР_XYZ";
	ПустойКод = "";

	// Act
	Результат = ЦенныеБумагиСервер.ЗагрузитьИзMOEX(НесуществующийТикер, ПустойКод);

	// Assert
	ЮТест.ОжидаетЧто(Результат.Успех).ЭтоЛожь("TC-003: Успех = Ложь");

	ЮТест.ОжидаетЧто(Результат.КодОшибки).Равно("БумагаНеНайдена", "TC-003: КодОшибки");

	ЮТест.ОжидаетЧто(Результат.ТекстОшибки).Заполнено("TC-003: ТекстОшибки заполнен");

КонецПроцедуры

// TC-006: Ручное заполнение реквизитов без вызова API.
//
Процедура ТС006_РучноеЗаполнениеБезИнтерфейсаПрограммирования() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		НовыйЭлемент = Справочники.ЦенныеБумаги.СоздатьЭлемент();
		НовыйЭлемент.Наименование = "Тестовая бумага";
		НовыйЭлемент.Тикер = "TEST";
		НовыйЭлемент.ISIN = "XX0000000001";
		НовыйЭлемент.ТипБумаги = "Тестовый тип";

		// Act
		ЕстьОшибка = Ложь;
		Попытка
			НовыйЭлемент.Записать();
		Исключение
			ЕстьОшибка = Истина;
		КонецПопытки;

		// Assert
		ЮТест.ОжидаетЧто(ЕстьОшибка).ЭтоЛожь("TC-006: запись ручных данных без ошибок");

		ЮТест.ОжидаетЧто(НовыйЭлемент.ДатаЗагрузки).Равно('00010101000000', "TC-006: ДатаЗагрузки пустая");

		// Очистка
		Если Не НовыйЭлемент.Ссылка.Пустая() Тогда
			НовыйЭлемент.Удалить();
		КонецЕсли;

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// TC-009: Уникальность ISIN - дублирующий код должен быть отклонен.
//
Процедура ТС009_ДублирующийМеждународныйКодВызываетОтказ() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ДублируемыйКод = "RU9999999999";

		ПервыйЭлемент = Справочники.ЦенныеБумаги.СоздатьЭлемент();
		ПервыйЭлемент.Наименование = "Первая тестовая бумага";
		ПервыйЭлемент.Тикер = "TST1";
		ПервыйЭлемент.ISIN = ДублируемыйКод;
		ПервыйЭлемент.Записать();

		// Act - вызываем ПроверитьЗаполнение (ОбработкаПроверкиЗаполнения не вызывается при программной записи)
		ВторойЭлемент = Справочники.ЦенныеБумаги.СоздатьЭлемент();
		ВторойЭлемент.Наименование = "Вторая тестовая бумага с дублем";
		ВторойЭлемент.Тикер = "TST2";
		ВторойЭлемент.ISIN = ДублируемыйКод;

		РезультатПроверки = ВторойЭлемент.ПроверитьЗаполнение();

		// Assert
		ЮТест.ОжидаетЧто(РезультатПроверки).ЭтоЛожь("TC-009: дублирующий ISIN отклонен ПроверитьЗаполнение");

		// Очистка
		Если Не ПервыйЭлемент.Ссылка.Пустая() Тогда
			ПервыйЭлемент.Удалить();
		КонецЕсли;

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти
