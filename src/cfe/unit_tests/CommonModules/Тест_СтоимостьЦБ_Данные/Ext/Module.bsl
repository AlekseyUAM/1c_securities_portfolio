// Тест-модуль YaxUnit: Тест_СтоимостьЦБ_Данные
// Покрывает сценарий T-17 из Test Plan (SPEC-007).
// T-17: Остатки корректны на указанную дату + запись не содержит ошибок (R-10, R-11, R-12, R-13, AC-06, AC-07, AC-08, AC-09).
// Также покрывает MUST сценарии spec T-11..T-13 и SHOULD T-15 (в нумерации task description).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("СтоимостьЦБ_Данные")
			.ДобавитьСерверныйТест("ТестТ17аОстаткиНаДату")
			.ДобавитьСерверныйТест("ТестТ17бВычисляемоеПолеИтоговаяСтоимость")
			.ДобавитьСерверныйТест("ТестТ17вГруппировкаЦБПоПартиям")
			.ДобавитьСерверныйТест("ТестТ17гОтсутствиеЗаписейПриФормировании")
			.ДобавитьСерверныйТест("ТестТ17дПустыеОстатки");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-17а: Остатки на дату — движение до ДатаОтчета попадает в остатки, движение после — нет.
// Связь: R-10, R-11, AC-06 (spec T-11).
//
Процедура ТестТ17аОстаткиНаДату() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: ЦБ и документ поступления (партия)
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		Партия = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		// Движение ДО даты отчета (10 января 2026)
		НаборДо = РегистрыНакопления.СобственныеЦБ.СоздатьНаборЗаписей();
		НаборДо.Отбор.Регистратор.Установить(Партия);
		ЗаписьДо = НаборДо.Добавить();
		ЗаписьДо.Период = '20260110';
		ЗаписьДо.ВидДвижения = ВидДвиженияНакопления.Приход;
		ЗаписьДо.ЦеннаяБумага = ЦБ;
		ЗаписьДо.Партия = Партия;
		ЗаписьДо.Количество = 100;
		ЗаписьДо.Стоимость = 5000;
		ЗаписьДо.Переоценка = 200;
		ЗаписьДо.Затраты = 50;
		ЗаписьДо.НКДПолученный = 10;
		ЗаписьДо.НКДНакопленный = 5;
		НаборДо.Записать();

		// Движение ПОСЛЕ даты отчета (1 февраля 2026 — после ДатаОтчета 31 января).
		// Используем отдельный документ как регистратор, чтобы набор записей был уникален.
		ДокументПосле = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");
		НаборПосле = РегистрыНакопления.СобственныеЦБ.СоздатьНаборЗаписей();
		НаборПосле.Отбор.Регистратор.Установить(ДокументПосле);
		ЗаписьПосле = НаборПосле.Добавить();
		ЗаписьПосле.Период = '20260201';
		ЗаписьПосле.ВидДвижения = ВидДвиженияНакопления.Приход;
		ЗаписьПосле.ЦеннаяБумага = ЦБ;
		ЗаписьПосле.Партия = Партия;
		ЗаписьПосле.Количество = 9999;
		ЗаписьПосле.Стоимость = 99999;
		ЗаписьПосле.Переоценка = 0;
		ЗаписьПосле.Затраты = 0;
		ЗаписьПосле.НКДПолученный = 0;
		ЗаписьПосле.НКДНакопленный = 0;
		НаборПосле.Записать();

		// Act: формируем отчет на 31 января 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ДатаОтчета", '20260131');

		РезультатОтчета = СформироватьОтчетСтоимостьЦБ(ПараметрыОтчета);

		// Assert: в результате только движение до даты
		НайденаЦБ = Ложь;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ Тогда
				НайденаЦБ = Истина;
				// Количество должно быть 100, не 100+9999
				ЮТест.ОжидаетЧто(Строка.Количество)
					.Равно(100, "Остаток на 31.01 должен включать только движение 10.01 (100), не 01.02 (9999)");
				Прервать;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(НайденаЦБ)
			.ЭтоИстина("ЦБ с движением до ДатаОтчета должна присутствовать в остатках");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-17б: Вычисляемое поле ИтоговаяСтоимость = Стоимость + Переоценка.
// Связь: R-12, AC-07 (spec T-12).
//
Процедура ТестТ17бВычисляемоеПолеИтоговаяСтоимость() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: ЦБ с известными значениями Стоимость и Переоценка
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		Партия = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		ОжидаемаяСтоимость = 10000;
		ОжидаемаяПереоценка = 1500;
		ОжидаемаяИтоговаяСтоимость = ОжидаемаяСтоимость + ОжидаемаяПереоценка; // 11500

		НаборЗаписей = РегистрыНакопления.СобственныеЦБ.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Партия);
		Запись = НаборЗаписей.Добавить();
		Запись.Период = '20260115';
		Запись.ВидДвижения = ВидДвиженияНакопления.Приход;
		Запись.ЦеннаяБумага = ЦБ;
		Запись.Партия = Партия;
		Запись.Количество = 50;
		Запись.Стоимость = ОжидаемаяСтоимость;
		Запись.Переоценка = ОжидаемаяПереоценка;
		Запись.Затраты = 100;
		Запись.НКДПолученный = 20;
		Запись.НКДНакопленный = 10;
		НаборЗаписей.Записать();

		// Act: формируем отчет на 31 января 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ДатаОтчета", '20260131');

		РезультатОтчета = СформироватьОтчетСтоимостьЦБ(ПараметрыОтчета);

		// Assert: ИтоговаяСтоимость = Стоимость + Переоценка
		НайденаЦБ = Ложь;
		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ Тогда
				НайденаЦБ = Истина;
				ЮТест.ОжидаетЧто(Строка.ИтоговаяСтоимость)
					.Равно(ОжидаемаяИтоговаяСтоимость,
						СтрШаблон("ИтоговаяСтоимость должна быть %1 (Стоимость %2 + Переоценка %3)",
							ОжидаемаяИтоговаяСтоимость, ОжидаемаяСтоимость, ОжидаемаяПереоценка));
				Прервать;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(НайденаЦБ)
			.ЭтоИстина("ЦБ должна присутствовать в результате для проверки ИтоговойСтоимости");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-17в: Группировка ЦеннаяБумага → Партия — две партии одной ЦБ → две строки под одной группой.
// Связь: R-13, AC-06 (spec T-13).
//
Процедура ТестТ17вГруппировкаЦБПоПартиям() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange: одна ЦБ, две разные партии (два документа поступления)
		ЦБ = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		Партия1 = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");
		Партия2 = ЮТест.Данные().СоздатьЭлемент("Документ.ПоступлениеВыбытиеЦБ");

		// Движение партии 1
		НаборЗаписей1 = РегистрыНакопления.СобственныеЦБ.СоздатьНаборЗаписей();
		НаборЗаписей1.Отбор.Регистратор.Установить(Партия1);
		Запись1 = НаборЗаписей1.Добавить();
		Запись1.Период = '20260105';
		Запись1.ВидДвижения = ВидДвиженияНакопления.Приход;
		Запись1.ЦеннаяБумага = ЦБ;
		Запись1.Партия = Партия1;
		Запись1.Количество = 100;
		Запись1.Стоимость = 5000;
		Запись1.Переоценка = 100;
		Запись1.Затраты = 50;
		Запись1.НКДПолученный = 10;
		Запись1.НКДНакопленный = 5;
		НаборЗаписей1.Записать();

		// Движение партии 2
		НаборЗаписей2 = РегистрыНакопления.СобственныеЦБ.СоздатьНаборЗаписей();
		НаборЗаписей2.Отбор.Регистратор.Установить(Партия2);
		Запись2 = НаборЗаписей2.Добавить();
		Запись2.Период = '20260110';
		Запись2.ВидДвижения = ВидДвиженияНакопления.Приход;
		Запись2.ЦеннаяБумага = ЦБ;
		Запись2.Партия = Партия2;
		Запись2.Количество = 50;
		Запись2.Стоимость = 2500;
		Запись2.Переоценка = 75;
		Запись2.Затраты = 25;
		Запись2.НКДПолученный = 5;
		Запись2.НКДНакопленный = 3;
		НаборЗаписей2.Записать();

		// Act: формируем отчет на 31 января 2026
		ПараметрыОтчета = Новый Структура;
		ПараметрыОтчета.Вставить("ДатаОтчета", '20260131');

		РезультатОтчета = СформироватьОтчетСтоимостьЦБ(ПараметрыОтчета);

		// Assert: в результате должны быть строки для обеих партий одной ЦБ.
		// Фильтруем только детальные строки (Партия заполнена), исключая итоговые строки СКД.
		КоличествоДетальныхСтрокДляЦБ = 0;
		НайденаПартия1 = Ложь;
		НайденаПартия2 = Ложь;

		Для Каждого Строка Из РезультатОтчета Цикл
			Если Строка.ЦеннаяБумага = ЦБ И ЗначениеЗаполнено(Строка.Партия) Тогда
				КоличествоДетальныхСтрокДляЦБ = КоличествоДетальныхСтрокДляЦБ + 1;
				Если Строка.Партия = Партия1 Тогда
					НайденаПартия1 = Истина;
				КонецЕсли;
				Если Строка.Партия = Партия2 Тогда
					НайденаПартия2 = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;

		ЮТест.ОжидаетЧто(КоличествоДетальныхСтрокДляЦБ)
			.Равно(2, "Для одной ЦБ с двумя партиями должно быть две детальные строки в результате");
		ЮТест.ОжидаетЧто(НайденаПартия1)
			.ЭтоИстина("Партия 1 должна присутствовать в результате");
		ЮТест.ОжидаетЧто(НайденаПартия2)
			.ЭтоИстина("Партия 2 должна присутствовать в результате");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-17г: Отсутствие записей в ИБ при формировании отчета (только для чтения).
// Связь: R-14, R-23, AC-09 (spec T-17).
// Фиксируем количество записей в регистрах до и после формирования всех трех отчетов.
// Количество не должно измениться.
//
Процедура ТестТ17гОтсутствиеЗаписейПриФормировании() Экспорт

	// Arrange: подсчет записей до формирования отчетов
	КоличествоДо_КотировкиЦБ = ПодсчитатьЗаписиКотировкиЦБ();
	КоличествоДо_ФинРезультат = ПодсчитатьЗаписиФинансовыйРезультат();
	КоличествоДо_СобственныеЦБ = ПодсчитатьЗаписиСобственныеЦБ();

	// Act: формируем все три отчета
	ПараметрыКотировкиЦБ = Новый Структура;
	ПараметрыКотировкиЦБ.Вставить("ЦеннаяБумага", Справочники.ЦенныеБумаги.ПустаяСсылка());
	ПараметрыКотировкиЦБ.Вставить("НачалоПериода", '20260101');
	ПараметрыКотировкиЦБ.Вставить("КонецПериода", '20260131');

	ПараметрыФинРезультат = Новый Структура;
	ПараметрыФинРезультат.Вставить("НачалоПериода", '20260101');
	ПараметрыФинРезультат.Вставить("КонецПериода", '20260131');

	ПараметрыСтоимостьЦБ = Новый Структура;
	ПараметрыСтоимостьЦБ.Вставить("ДатаОтчета", '20260131');

	// Формируем отчеты (игнорируем результаты, нас интересует только отсутствие побочных эффектов)
	ВызваноИсключение = Ложь;
	Попытка
		СформироватьОтчетКотировкаЦБ(ПараметрыКотировкиЦБ);
		СформироватьОтчетФинансовыйРезультат(ПараметрыФинРезультат);
		СформироватьОтчетСтоимостьЦБ(ПараметрыСтоимостьЦБ);
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	// Assert: формирование без ошибок
	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Формирование всех трех отчетов не должно вызывать исключений");

	// Assert: количество записей не изменилось
	КоличествоПосле_КотировкиЦБ = ПодсчитатьЗаписиКотировкиЦБ();
	КоличествоПосле_ФинРезультат = ПодсчитатьЗаписиФинансовыйРезультат();
	КоличествоПосле_СобственныеЦБ = ПодсчитатьЗаписиСобственныеЦБ();

	ЮТест.ОжидаетЧто(КоличествоПосле_КотировкиЦБ)
		.Равно(КоличествоДо_КотировкиЦБ, "Формирование отчетов не должно изменять регистр КотировкиЦБ");
	ЮТест.ОжидаетЧто(КоличествоПосле_ФинРезультат)
		.Равно(КоличествоДо_ФинРезультат, "Формирование отчетов не должно изменять регистр ФинансовыйРезультат");
	ЮТест.ОжидаетЧто(КоличествоПосле_СобственныеЦБ)
		.Равно(КоличествоДо_СобственныеЦБ, "Формирование отчетов не должно изменять регистр СобственныеЦБ");

КонецПроцедуры

// T-17д: Пустые остатки — при нулевых остатках или ДатаОтчета до первого движения.
// Связь: SHOULD T-15 в spec.
//
Процедура ТестТ17дПустыеОстатки() Экспорт

	// Arrange: дата отчета в прошлом (до первых движений в базе)
	ПараметрыОтчета = Новый Структура;
	ПараметрыОтчета.Вставить("ДатаОтчета", '20000101');

	// Act: формируем отчет
	ВызваноИсключение = Ложь;
	РезультатОтчета = Неопределено;
	Попытка
		РезультатОтчета = СформироватьОтчетСтоимостьЦБ(ПараметрыОтчета);
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	// Assert: формирование без ошибок
	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Отчет при нулевых остатках должен формироваться без исключений");

	// Assert: результат пустой (нет остатков до 01.01.2000)
	ЮТест.ОжидаетЧто(РезультатОтчета.Количество())
		.Равно(0, "При отсутствии остатков на указанную дату результат должен быть пустым");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует отчет СтоимостьЦБ через СКД и возвращает таблицу значений.
//
// Параметры:
//   ПараметрыОтчета - Структура - ключи: ДатаОтчета.
//
// Возвращаемое значение:
//   ТаблицаЗначений - строки результата компоновки.
//
Функция СформироватьОтчетСтоимостьЦБ(ПараметрыОтчета)

	ОтчетОбъект = Отчеты.СтоимостьЦБ.Создать();

	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(
			ОтчетОбъект.СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(
		ОтчетОбъект.СхемаКомпоновкиДанных.НастройкиПоУмолчанию);

	// Установка параметров
	Для Каждого КлючЗначение Из ПараметрыОтчета Цикл
		КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(
			КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(
		ОтчетОбъект.СхемаКомпоновкиДанных,
		КомпоновщикНастроек.Настройки,,,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);

	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
