// Тест-модуль YaxUnit: Тест_КотировкаЦБ_Базовый
// Покрывает сценарии T-01, T-02 из Test Plan (SPEC-007).
// T-01: Отчет создан и доступен (AC-01).
// T-02: Параметры ЦеннаяБумага, НачалоПериода, КонецПериода присутствуют (R-02).
// Фаза 3а (Red): тесты написаны до реализации — должны падать до создания объектов метаданных.

#Область ПрограммныйИнтерфейс

// Регистрация тестовых наборов для YaxUnit.
//
Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("КотировкаЦБ_Базовый")
			.ДобавитьСерверныйТест("ТестТ01ОтчетСуществует")
			.ДобавитьСерверныйТест("ТестТ02ПараметрыПрисутствуют");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-01: Отчет КотировкаЦБ создан и доступен.
// Связь: R-01, AC-01.
// Тест проверяет, что объект метаданных Отчет.КотировкаЦБ существует в конфигурации
// и может быть создан без исключений.
//
Процедура ТестТ01ОтчетСуществует() Экспорт

	// Arrange: ничего не требуется

	// Act: проверяем наличие объекта в метаданных
	МетаданныеОтчета = Метаданные.Отчеты.Найти("КотировкаЦБ");

	// Assert: объект метаданных должен существовать
	ЮТест.ОжидаетЧто(МетаданныеОтчета)
		.НеРавно(Неопределено, "Метаданные.Отчеты.КотировкаЦБ должен существовать");

	// Дополнительно: отчет должен открываться без исключений
	ВызваноИсключение = Ложь;
	Попытка
		ОтчетОбъект = Отчеты.КотировкаЦБ.Создать();
	Исключение
		ВызваноИсключение = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ВызваноИсключение)
		.ЭтоЛожь("Создание экземпляра Отчеты.КотировкаЦБ.Создать() не должно вызывать исключение");

КонецПроцедуры

// T-02: Параметры ЦеннаяБумага, НачалоПериода, КонецПериода присутствуют в СКД отчета.
// Связь: R-02, AC-02.
// Тест проверяет, что СКД отчета содержит все обязательные параметры с корректными именами.
//
Процедура ТестТ02ПараметрыПрисутствуют() Экспорт

	// Arrange: получаем объект отчета и его схему компоновки данных
	ОтчетОбъект = Отчеты.КотировкаЦБ.Создать();
	СхемаКД = ОтчетОбъект.СхемаКомпоновкиДанных;

	// Act: получаем параметры схемы
	ПараметрыСхемы = СхемаКД.Параметры;

	// Формируем список имен параметров
	ИменаПараметров = Новый Массив;
	Для Каждого Параметр Из ПараметрыСхемы Цикл
		ИменаПараметров.Добавить(Параметр.Имя);
	КонецЦикла;

	// Assert: параметр ЦеннаяБумага должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("ЦеннаяБумага", "Параметр ЦеннаяБумага должен присутствовать в СКД");

	// Assert: параметр НачалоПериода должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("НачалоПериода", "Параметр НачалоПериода должен присутствовать в СКД");

	// Assert: параметр КонецПериода должен присутствовать
	ЮТест.ОжидаетЧто(ИменаПараметров)
		.Содержит("КонецПериода", "Параметр КонецПериода должен присутствовать в СКД");

КонецПроцедуры

#КонецОбласти
