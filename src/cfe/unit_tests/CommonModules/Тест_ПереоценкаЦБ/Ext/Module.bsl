#Область ПрограммныйИнтерфейс

Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("ПоложительнаяПереоценка")
			.ДобавитьСерверныйТест("ТестПоложительнаяПереоценкаОднаПартия")
		.ДобавитьТестовыйНабор("ОтрицательнаяПереоценка")
			.ДобавитьСерверныйТест("ТестОтрицательнаяПереоценкаОднаПартия")
		.ДобавитьТестовыйНабор("НесколькоПартий")
			.ДобавитьСерверныйТест("ТестПереоценкаДвеПартии")
		.ДобавитьТестовыйНабор("НетКотировки")
			.ДобавитьСерверныйТест("ТестНетКотировкиНетДвижений")
		.ДобавитьТестовыйНабор("НетОстатков")
			.ДобавитьСерверныйТест("ТестНетОстатковНетДвижений")
		.ДобавитьТестовыйНабор("НулеваяРазница")
			.ДобавитьСерверныйТест("ТестНулеваяРазницаНетДвижений")
		.ДобавитьТестовыйНабор("ПовторнаяПереоценка")
			.ДобавитьСерверныйТест("ТестПереоценкаПослеПереоценки");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// T-001: Положительная переоценка одной партии
Процедура ТестПоложительнаяПереоценкаОднаПартия() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Пер01");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 0, 0);
		СоздатьКотировку(ЦеннаяБумага, ТекущаяДатаСеанса(), 60);

		ДокПереоценка = Документы.ПереоценкаЦБ.СоздатьДокумент();
		ДокПереоценка.Дата = ТекущаяДатаСеанса();
		ДокПереоценка.Записать(РежимЗаписиДокумента.Проведение);

		// РыночнаяСтоимость = 100 * 60 = 6000
		// БалансоваяСтоимость = 5000 + 0 = 5000
		// Разница = 1000
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.ВидДвижения КАК ВидДвижения,
		|	Движения.Переоценка КАК Переоценка,
		|	Движения.Количество КАК Количество,
		|	Движения.Стоимость КАК Стоимость,
		|	Движения.Затраты КАК Затраты,
		|	Движения.НКДПолученный КАК НКДПолученный,
		|	Движения.НКДНакопленный КАК НКДНакопленный
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|	И Движения.ЦеннаяБумага = &ЦеннаяБумага";
		Запрос.УстановитьПараметр("Регистратор", ДокПереоценка.Ссылка);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(1, "одно движение переоценки");
		ЮТест.ОжидаетЧто(Таблица[0].ВидДвижения).Равно(ВидДвиженияНакопления.Приход, "приход");
		ЮТест.ОжидаетЧто(Таблица[0].Переоценка).Равно(1000, "переоценка = 1000");
		ЮТест.ОжидаетЧто(Таблица[0].Количество).Равно(0, "количество = 0");
		ЮТест.ОжидаетЧто(Таблица[0].Стоимость).Равно(0, "стоимость = 0");
		ЮТест.ОжидаетЧто(Таблица[0].Затраты).Равно(0, "затраты = 0");
		ЮТест.ОжидаетЧто(Таблица[0].НКДПолученный).Равно(0, "НКДПолученный = 0");
		ЮТест.ОжидаетЧто(Таблица[0].НКДНакопленный).Равно(0, "НКДНакопленный = 0");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-002: Отрицательная переоценка
Процедура ТестОтрицательнаяПереоценкаОднаПартия() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Пер02");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 0, 0);
		СоздатьКотировку(ЦеннаяБумага, ТекущаяДатаСеанса(), 40);

		ДокПереоценка = Документы.ПереоценкаЦБ.СоздатьДокумент();
		ДокПереоценка.Дата = ТекущаяДатаСеанса();
		ДокПереоценка.Записать(РежимЗаписиДокумента.Проведение);

		// Разница = 100*40 - 5000 = -1000
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.ВидДвижения КАК ВидДвижения,
		|	Движения.Переоценка КАК Переоценка
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|	И Движения.ЦеннаяБумага = &ЦеннаяБумага";
		Запрос.УстановитьПараметр("Регистратор", ДокПереоценка.Ссылка);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(1, "одно движение");
		ЮТест.ОжидаетЧто(Таблица[0].ВидДвижения).Равно(ВидДвиженияНакопления.Приход, "приход");
		ЮТест.ОжидаетЧто(Таблица[0].Переоценка).Равно(-1000, "переоценка = -1000");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-003: Две партии
Процедура ТестПереоценкаДвеПартии() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Пер03");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 60, 100, 0, 0);
		СоздатьИПровестиПоступление(ЦеннаяБумага, 40, 100, 0, 0);
		СоздатьКотировку(ЦеннаяБумага, ТекущаяДатаСеанса(), 110);

		ДокПереоценка = Документы.ПереоценкаЦБ.СоздатьДокумент();
		ДокПереоценка.Дата = ТекущаяДатаСеанса();
		ДокПереоценка.Записать(РежимЗаписиДокумента.Проведение);

		// Партия1: 60*110 - 6000 = 600, Партия2: 40*110 - 4000 = 400
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.Переоценка КАК Переоценка
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|УПОРЯДОЧИТЬ ПО
		|	Движения.Переоценка УБЫВ";
		Запрос.УстановитьПараметр("Регистратор", ДокПереоценка.Ссылка);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(2, "два движения");
		ЮТест.ОжидаетЧто(Таблица.Итог("Переоценка")).Равно(1000, "сумма переоценки = 1000");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

