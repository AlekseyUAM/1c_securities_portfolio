// T-008: Переоценка после переоценки
Процедура ТестПереоценкаПослеПереоценки() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("Пер08");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 100, 50, 0, 0);

		// Первая переоценка: котировка 60 → разница = 1000
		СоздатьКотировку(ЦеннаяБумага, ТекущаяДатаСеанса(), 60);
		ДокПереоценка1 = Документы.ПереоценкаЦБ.СоздатьДокумент();
		ДокПереоценка1.Дата = ТекущаяДатаСеанса();
		ДокПереоценка1.Записать(РежимЗаписиДокумента.Проведение);

		// Вторая переоценка: котировка 70 → 100*70=7000, балансовая = 5000+1000=6000, разница = 1000
		СоздатьКотировку(ЦеннаяБумага, ТекущаяДатаСеанса(), 70);
		ДокПереоценка2 = Документы.ПереоценкаЦБ.СоздатьДокумент();
		ДокПереоценка2.Дата = ТекущаяДатаСеанса();
		ДокПереоценка2.Записать(РежимЗаписиДокумента.Проведение);

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.Переоценка КАК Переоценка
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор
		|	И Движения.ЦеннаяБумага = &ЦеннаяБумага";
		Запрос.УстановитьПараметр("Регистратор", ДокПереоценка2.Ссылка);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(1, "одно движение второй переоценки");
		ЮТест.ОжидаетЧто(Таблица[0].Переоценка).Равно(1000, "вторая переоценка = 1000 (учтена первая)");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СоздатьТестовуюЦБ(Префикс)

	НовыйЭлемент = Справочники.ЦенныеБумаги.СоздатьЭлемент();
	НовыйЭлемент.Наименование = Префикс + "_ТестоваяЦБ_" + Строка(Новый УникальныйИдентификатор);
	НовыйЭлемент.Тикер = Лев(Префикс, 10);
	НовыйЭлемент.Записать();

	Возврат НовыйЭлемент.Ссылка;

КонецФункции

Функция СоздатьИПровестиПоступление(ЦеннаяБумага, Количество, Цена, НКД, СуммаКомиссии)

	ДокументОбъект = Документы.ПоступлениеВыбытиеЦБ.СоздатьДокумент();
	ДокументОбъект.Дата = НачалоДня(ТекущаяДатаСеанса()) - 1;
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЦБ.Поступление;
	ДокументОбъект.ЦеннаяБумага = ЦеннаяБумага;
	ДокументОбъект.Количество = Количество;
	ДокументОбъект.Цена = Цена;
	ДокументОбъект.НКД = НКД;

	Если СуммаКомиссии > 0 Тогда
		СтрокаКомиссии = ДокументОбъект.Комиссии.Добавить();
		СтрокаКомиссии.ВидКомиссии = Перечисления.ВидыКомиссий.БрокерскаяКомиссия;
		СтрокаКомиссии.Сумма = СуммаКомиссии;
	КонецЕсли;

	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

	Возврат ДокументОбъект.Ссылка;

КонецФункции

Процедура СоздатьКотировку(ЦеннаяБумага, ДатаКотировки, Значение)

	НаборЗаписей = РегистрыСведений.КотировкиЦБ.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЦеннаяБумага.Установить(ЦеннаяБумага);
	НаборЗаписей.Отбор.ВидКотировки.Установить(Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия);
	НаборЗаписей.Отбор.Период.Установить(ДатаКотировки);

	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.Период = ДатаКотировки;
	НоваяЗапись.ЦеннаяБумага = ЦеннаяБумага;
	НоваяЗапись.ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;
	НоваяЗапись.Значение = Значение;
	НаборЗаписей.Записать();

КонецПроцедуры

#КонецОбласти
