#Область ПрограммныйИнтерфейс

Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.ДобавитьТестовыйНабор("БазовоеНачисление")
			.ДобавитьСерверныйТест("ТестОднаПартияНКД")
			.ДобавитьСерверныйТест("ТестДвеПартииНКД")
		.ДобавитьТестовыйНабор("НетОстатков")
			.ДобавитьСерверныйТест("ТестНетОстатковОтказ")
		.ДобавитьТестовыйНабор("НулевыеРесурсы")
			.ДобавитьСерверныйТест("ТестПрочиеРесурсыНулевые")
		.ДобавитьТестовыйНабор("НетФинРез")
			.ДобавитьСерверныйТест("ТестНетДвиженийФинансовыйРезультат")
		.ДобавитьТестовыйНабор("Перепроведение")
			.ДобавитьСерверныйТест("ТестПерепроведениеЗаменяетДвижения");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// TP-01: Одна партия, НКД = 2 на штуку, 50 шт → НКДНакопленный = 100
Процедура ТестОднаПартияНКД() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("НКД01");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 50, 100, 0, 0);

		ДокНКД = Документы.НачислениеНКД.СоздатьДокумент();
		ДокНКД.Дата = ТекущаяДатаСеанса();
		ДокНКД.ЦеннаяБумага = ЦеннаяБумага;
		ДокНКД.НКД = 2;
		ДокНКД.Записать(РежимЗаписиДокумента.Проведение);

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.НКДНакопленный КАК НКДНакопленный,
		|	Движения.ВидДвижения КАК ВидДвижения
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокНКД.Ссылка);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(1, "одно движение");
		ЮТест.ОжидаетЧто(Таблица[0].ВидДвижения).Равно(ВидДвиженияНакопления.Приход, "приход");
		ЮТест.ОжидаетЧто(Таблица[0].НКДНакопленный).Равно(100, "НКД = 2 * 50 = 100");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// TP-02: Две партии (60 и 40 шт), НКД = 1 → 60 и 40
Процедура ТестДвеПартииНКД() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("НКД02");
		СоздатьИПровестиПоступление(ЦеннаяБумага, 60, 100, 0, 0);
		СоздатьИПровестиПоступление(ЦеннаяБумага, 40, 100, 0, 0);

		ДокНКД = Документы.НачислениеНКД.СоздатьДокумент();
		ДокНКД.Дата = ТекущаяДатаСеанса();
		ДокНКД.ЦеннаяБумага = ЦеннаяБумага;
		ДокНКД.НКД = 1;
		ДокНКД.Записать(РежимЗаписиДокумента.Проведение);

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Движения.НКДНакопленный КАК НКДНакопленный
		|ИЗ
		|	РегистрНакопления.СобственныеЦБ КАК Движения
		|ГДЕ
		|	Движения.Регистратор = &Регистратор";
		Запрос.УстановитьПараметр("Регистратор", ДокНКД.Ссылка);

		Таблица = Запрос.Выполнить().Выгрузить();
		ЮТест.ОжидаетЧто(Таблица.Количество()).Равно(2, "два движения");
		ЮТест.ОжидаетЧто(Таблица.Итог("НКДНакопленный")).Равно(100, "итого НКД = 60 + 40 = 100");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// TP-04: Нет остатков → Отказ
Процедура ТестНетОстатковОтказ() Экспорт

	НачатьТранзакцию();
	Попытка

		ЦеннаяБумага = СоздатьТестовуюЦБ("НКД04");

		ДокНКД = Документы.НачислениеНКД.СоздатьДокумент();
		ДокНКД.Дата = ТекущаяДатаСеанса();
		ДокНКД.ЦеннаяБумага = ЦеннаяБумага;
		ДокНКД.НКД = 10;

		ВызваноИсключение = Ложь;
		Попытка
			ДокНКД.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ВызваноИсключение = Истина;
		КонецПопытки;

		ЮТест.ОжидаетЧто(ВызваноИсключение).ЭтоИстина("проведение отменено: нет остатков");

		ОтменитьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

