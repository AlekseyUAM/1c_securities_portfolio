// T-MUST-08: Обработка пагинации.
// Связь: R-MUST-06.
//
Процедура Тест08Пагинация() Экспорт

	// Arrange: первая страница (INDEX=0, TOTAL=5, PAGESIZE=3)
	ТелоСтраница1 = ПолучитьОтветПагинацияСтраница1();

