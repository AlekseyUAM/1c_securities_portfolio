// ============================================================
// Набор: ЗаписьВРегистр
// ============================================================

// T-MUST-01: Запись котировки в регистр и чтение.
// Связь: R-MUST-01.
//
Процедура Тест01ЗаписьИЧтениеКотировки() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;
		ДатаКотировки = '20250115';
		ЗначениеКотировки = 250.75;

		Котировки = Новый Соответствие;
		Котировки.Вставить(ДатаКотировки, ЗначениеКотировки);

		// Act
		РаботаСКотировкамиЦБ.ЗаписатьКотировкиВРегистр(ЦеннаяБумага, Котировки, ВидКотировки);

		// Assert
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КотировкиЦБ.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.КотировкиЦБ КАК КотировкиЦБ
		|ГДЕ
		|	КотировкиЦБ.Период = &Период
		|	И КотировкиЦБ.ЦеннаяБумага = &ЦеннаяБумага
		|	И КотировкиЦБ.ВидКотировки = &ВидКотировки";
		Запрос.УстановитьПараметр("Период", ДатаКотировки);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
		Запрос.УстановитьПараметр("ВидКотировки", ВидКотировки);

		РезультатЗапроса = Запрос.Выполнить();
		ЮТест.ОжидаетЧто(РезультатЗапроса.Пустой()).ЭтоЛожь("запись найдена в регистре");

		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЮТест.ОжидаетЧто(Выборка.Значение).Равно(ЗначениеКотировки, "значение котировки совпадает");

		// Откат транзакции для очистки тестовых данных
		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// T-MUST-10: Перезапись при повторной загрузке (upsert).
// Связь: R-MUST-10.
//
Процедура Тест10ПерезаписьПриПовторнойЗагрузке() Экспорт

	НачатьТранзакцию();
	Попытка

		// Arrange
		ЦеннаяБумага = ЮТест.Данные().СоздатьЭлемент("Справочник.ЦенныеБумаги");
		ВидКотировки = Перечисления.ВидыКотировокЦБ.ЦенаЗакрытия;
		ДатаКотировки = '20250220';

		// Первая загрузка
		КотировкиВерсия1 = Новый Соответствие;
		КотировкиВерсия1.Вставить(ДатаКотировки, 100.0);
		РаботаСКотировкамиЦБ.ЗаписатьКотировкиВРегистр(ЦеннаяБумага, КотировкиВерсия1, ВидКотировки);

		// Act: повторная загрузка с другим значением
		КотировкиВерсия2 = Новый Соответствие;
		КотировкиВерсия2.Вставить(ДатаКотировки, 105.5);
		РаботаСКотировкамиЦБ.ЗаписатьКотировкиВРегистр(ЦеннаяБумага, КотировкиВерсия2, ВидКотировки);

		// Assert
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КотировкиЦБ.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.КотировкиЦБ КАК КотировкиЦБ
		|ГДЕ
		|	КотировкиЦБ.Период = &Период
		|	И КотировкиЦБ.ЦеннаяБумага = &ЦеннаяБумага
		|	И КотировкиЦБ.ВидКотировки = &ВидКотировки";
		Запрос.УстановитьПараметр("Период", ДатаКотировки);
		Запрос.УстановитьПараметр("ЦеннаяБумага", ЦеннаяБумага);
		Запрос.УстановитьПараметр("ВидКотировки", ВидКотировки);

		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();

		КоличествоЗаписей = 0;
		ПоследнееЗначение = 0;
		Пока Выборка.Следующий() Цикл
			КоличествоЗаписей = КоличествоЗаписей + 1;
			ПоследнееЗначение = Выборка.Значение;
		КонецЦикла;

		ЮТест.ОжидаетЧто(КоличествоЗаписей).Равно(1, "ровно одна запись, нет дубликатов");
		ЮТест.ОжидаетЧто(ПоследнееЗначение).Равно(105.5, "значение обновлено");

		// Откат транзакции для очистки тестовых данных
		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
