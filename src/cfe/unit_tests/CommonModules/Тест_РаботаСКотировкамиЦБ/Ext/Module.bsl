			РаботаСКотировкамиЦБ.ЗаписатьКотировкиВРегистр(ЦеннаяБумага, ПустыеКотировки, ВидКотировки);
		Исключение
			ВызваноИсключение = Истина;
		КонецПопытки;

		// Assert
		ЮТест.ОжидаетЧто(ВызваноИсключение).ЭтоЛожь("запись пустого соответствия не вызывает ошибку");

		ОтменитьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

