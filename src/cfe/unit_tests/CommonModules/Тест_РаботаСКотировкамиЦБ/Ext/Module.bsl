// T-MUST-07: Откат на альтернативную цену при пустом CLOSE.
// Связь: R-MUST-07, R-MUST-09.
//
Процедура Тест07ОткатНаАльтернативнуюЦену() Экспорт

	// Arrange
	Записи = Новый Массив;

	ЗаписьОсновная = Новый Структура;
	ЗаписьОсновная.Вставить("BOARDID", "TQBR");
	ЗаписьОсновная.Вставить("TRADEDATE", "2025-01-15");
	ЗаписьОсновная.Вставить("CLOSE", Неопределено);
	ЗаписьОсновная.Вставить("LEGALCLOSEPRICE", 159.8);
	Записи.Добавить(ЗаписьОсновная);

	ЗаписьДополнительная = Новый Структура;
	ЗаписьДополнительная.Вставить("BOARDID", "TQPI");
	ЗаписьДополнительная.Вставить("TRADEDATE", "2025-01-15");
	ЗаписьДополнительная.Вставить("CLOSE", 160.5);
	ЗаписьДополнительная.Вставить("LEGALCLOSEPRICE", 160.5);
	Записи.Добавить(ЗаписьДополнительная);

	// Act
	Котировки = РаботаСКотировкамиЦБ.ОтфильтроватьПоBOARDID(Записи, "TQBR");

	// Assert
	ЮТест.ОжидаетЧто(Котировки).ИмеетТип("Соответствие", "результат - соответствие");

	ДатаКлюч = '20250115';
	ЮТест.ОжидаетЧто(Котировки[ДатаКлюч]).Равно(159.8, "откат на LEGALCLOSEPRICE = 159.8");

