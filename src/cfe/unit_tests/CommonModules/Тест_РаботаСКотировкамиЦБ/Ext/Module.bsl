//
Процедура ТестCloseРавенНулю() Экспорт

	Записи = Новый Массив;

	ЗаписьСНулем = Новый Структура;
	ЗаписьСНулем.Вставить("BOARDID", "TQCB");
	ЗаписьСНулем.Вставить("TRADEDATE", "2025-06-01");
	ЗаписьСНулем.Вставить("CLOSE", 0);
	ЗаписьСНулем.Вставить("LEGALCLOSEPRICE", 95.5);
	Записи.Добавить(ЗаписьСНулем);

	// Act
	Котировки = РаботаСКотировкамиЦБ.ОтфильтроватьПоBOARDID(Записи, "TQCB");

	// Assert: CLOSE=0 - валидное значение, должно быть использовано
	ДатаКлюч = '20250601';
	ЮТест.ОжидаетЧто(Котировки[ДатаКлюч]).Равно(0, "CLOSE=0 используется как валидное значение");

