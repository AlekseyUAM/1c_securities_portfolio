	ЮТест.ОжидаетЧто(НетСледующейСтраницы).ЭтоИстина("вторая страница последняя");

	// Суммарно 5 записей
	ВсегоЗаписей = Результат1.Записи.Количество() + Результат2.Записи.Количество();
	ЮТест.ОжидаетЧто(ВсегоЗаписей).Равно(5, "суммарно 5 записей из двух страниц");

