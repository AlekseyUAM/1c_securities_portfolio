// ============================================================
// Набор: ПарсингОтвета
// ============================================================

// T-MUST-06: Парсинг стандартного ответа.
// Связь: R-MUST-06, R-MUST-07.
//
Процедура Тест06ПарсингСтандартногоОтвета() Экспорт

	// Arrange
	ТелоОтвета = ПолучитьЭталонныйОтвет();

	// Act
	Результат = РаботаСКотировкамиЦБ.РазобратьОтветМОЕХ(ТелоОтвета);

	// Assert: структура результата
	ЮТест.ОжидаетЧто(Результат).ИмеетТип("Структура", "результат - структура");

	// Записи
	ЮТест.ОжидаетЧто(Результат.Записи).ИмеетТип("Массив", "Записи - массив");
	ЮТест.ОжидаетЧто(Результат.Записи.Количество()).Больше(0, "Записи не пусты");

	// Курсор для пагинации
	ЮТест.ОжидаетЧто(Результат.Курсор).ИмеетТип("Структура", "Курсор - структура");
	ЮТест.ОжидаетЧто(Результат.Курсор.TOTAL).ИмеетТип("Число", "TOTAL");
	ЮТест.ОжидаетЧто(Результат.Курсор.PAGESIZE).ИмеетТип("Число", "PAGESIZE");
	ЮТест.ОжидаетЧто(Результат.Курсор.INDEX).ИмеетТип("Число", "INDEX");

	// Колонки
	ЮТест.ОжидаетЧто(Результат.Колонки).ИмеетТип("Массив", "Колонки - массив");
	ЮТест.ОжидаетЧто(Результат.Колонки.Количество()).Больше(0, "Колонки не пусты");

	// Структура записи
	ПерваяЗапись = Результат.Записи[0];
	ЮТест.ОжидаетЧто(ПерваяЗапись).ИмеетТип("Структура", "запись - структура");

КонецПроцедуры

